@startuml
' Template: scoped use case diagram.
' Shows actors, use cases, associations, include/extend, and the system boundary.

left to right direction
skinparam shadowing false
skinparam actorStyle stickman
skinparam ArrowColor #333333
skinparam BorderColor #333333
skinparam usecase {
  BackgroundColor #FFF8D8
  BorderColor #333333
}

frame "uc Package Name" {
  ' Actors are external roles/systems. They belong outside the package boundary.
  actor "Primary Actor" as A_Primary
  actor "Secondary Actor" as A_Secondary

  rectangle "Package Name" {
    usecase "Main Use Case" as UC_Main
    usecase "Included Use Case" as UC_Included
    usecase "Optional Extension" as UC_Extension
    usecase "Specialised Use Case" as UC_Specialised
  }

  ' Solid actor associations: no arrowheads.
  A_Primary -- UC_Main
  A_Secondary -- UC_Included

  ' Include: base use case -> mandatory included use case.
  UC_Main .> UC_Included : <<include>>

  ' Extend: optional/conditional extension -> base use case. Record the condition
  ' here or in the project's linked textual requirement.
  UC_Extension .> UC_Main : <<extend>>
  note on link
    <<Condition>>
    Optional condition is true.
  end note

  ' Use case generalisation example: specialised use case -> general/base use case.
  UC_Specialised --|> UC_Main
}
@enduml
