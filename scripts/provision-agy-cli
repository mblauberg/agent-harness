#!/bin/sh
# Seed Fabric's versioned Agy executable from the Google-signed subscription CLI.
set -eu

mode=${1:-}
if [ "$mode" != "" ] && [ "$mode" != "--if-available" ]; then
  echo "usage: provision-agy-cli [--if-available]" >&2
  exit 2
fi

script_path=$0
while [ -L "$script_path" ]; do
  link=$(readlink "$script_path")
  case "$link" in
    /*) script_path=$link ;;
    *) script_path=$(dirname "$script_path")/$link ;;
  esac
done
script_dir=$(CDPATH= cd -- "$(dirname -- "$script_path")" && pwd)
agents_home=${AGENTS_HOME:-"$(dirname -- "$script_dir")"}
case "$agents_home" in /*) ;; *) echo "AGENTS_HOME must be absolute" >&2; exit 2 ;; esac

version=1.1.4
expected_sha=604c3fff9ce2f82f40f8049f0c0e311c1f51483e77e5e6b31cdfcc4aff2dbf37
source_path=${AGY_SOURCE:-"$HOME/.local/bin/agy"}
destination="$agents_home/.runtime/provider-clis/agy/$version/agy"

sha256() {
  shasum -a 256 "$1" | awk '{print $1}'
}

if [ -f "$destination" ]; then
  actual=$(sha256 "$destination")
  if [ "$actual" = "$expected_sha" ]; then
    exit 0
  fi
  echo "refusing changed managed Agy executable: $destination" >&2
  exit 1
fi

if [ ! -f "$source_path" ]; then
  if [ "$mode" = "--if-available" ]; then
    exit 0
  fi
  echo "Agy subscription CLI is unavailable: $source_path" >&2
  exit 1
fi

actual=$(sha256 "$source_path")
if [ "$actual" != "$expected_sha" ]; then
  if [ "$mode" = "--if-available" ]; then
    echo "Agy $version is not available for managed provisioning; leaving the optional adapter unavailable" >&2
    exit 0
  fi
  echo "Agy subscription CLI does not match the pinned $version digest: $source_path" >&2
  exit 1
fi

if [ "$(uname -s)" != "Darwin" ] || [ "$(uname -m)" != "arm64" ]; then
  echo "Agy $version compatibility is pinned only for darwin-arm64" >&2
  exit 1
fi
/usr/bin/codesign --verify --strict "$source_path"
signature=$(/usr/bin/codesign -dv --verbose=4 "$source_path" 2>&1)
printf '%s\n' "$signature" | grep -qx 'TeamIdentifier=EQHXZ8M8AV'
printf '%s\n' "$signature" | grep -qx 'Authority=Developer ID Application: Google LLC (EQHXZ8M8AV)'

destination_dir=$(dirname "$destination")
mkdir -p "$destination_dir"
temporary=$(mktemp "$destination_dir/.agy.XXXXXX")
trap 'rm -f "$temporary"' EXIT HUP INT TERM
cp "$source_path" "$temporary"
chmod 0700 "$temporary"
[ "$(sha256 "$temporary")" = "$expected_sha" ]
mv "$temporary" "$destination"
trap - EXIT HUP INT TERM
echo "provisioned Agy $version: $destination"
