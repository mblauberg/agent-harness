#!/bin/sh
# Rebuild the workspace dist when the compiled fabric CLI is absent or older
# than its TypeScript sources, so scripts/agent-fabric and
# scripts/agent-fabric-mcp keep executing compiled JS instead of falling back
# to the slow tsx loader path. No-op when the dist is already fresh.
set -eu

script_path=$0
while [ -L "$script_path" ]; do
  link=$(readlink "$script_path")
  case "$link" in
    /*) script_path=$link ;;
    *) script_path=$(dirname "$script_path")/$link ;;
  esac
done
script_dir=$(CDPATH= cd -- "$(dirname -- "$script_path")" && pwd)
agents_home=${AGENTS_HOME:-"$(dirname -- "$script_dir")"}
case "$agents_home" in /*) ;; *) echo "AGENTS_HOME must be absolute" >&2; exit 2 ;; esac
package_root="$agents_home/runtime/agent-fabric"

dist_cli="$package_root/dist/cli/main.js"
dist_mcp="$package_root/dist/mcp/main.js"
protocol_root="$agents_home/runtime/agent-fabric-protocol"
protocol_dist="$protocol_root/dist/index.js"
herdr_root="$agents_home/runtime/agent-fabric-herdr"
herdr_dist="$herdr_root/dist/cli.js"
console_root="$agents_home/runtime/agent-fabric-console"
console_dist="$console_root/dist/cli.js"

workspace_is_stale() {
  workspace=$1
  shift

  for output do
    [ -f "$output" ] || return 0

    if [ -d "$workspace/src" ] && find "$workspace/src" -type f -name '*.ts' -newer "$output" -print -quit | grep -q .; then
      return 0
    fi

    for input in "$workspace/package.json" "$workspace/tsconfig.json" "$workspace/tsconfig.build.json"; do
      [ ! -f "$input" ] || [ ! "$input" -nt "$output" ] || return 0
    done
  done

  return 1
}

workspace_stale=false
if workspace_is_stale "$protocol_root" "$protocol_dist" \
  || workspace_is_stale "$package_root" "$dist_cli" "$dist_mcp" \
  || workspace_is_stale "$herdr_root" "$herdr_dist" \
  || workspace_is_stale "$console_root" "$console_dist"; then
  workspace_stale=true
fi

# Root manifests define the project-reference build graph. A newer manifest
# invalidates the warm result even when no workspace source file changed.
for input in "$agents_home/package.json" "$agents_home/package-lock.json" "$agents_home/tsconfig.json"; do
  [ -f "$input" ] || continue
  for output in "$protocol_dist" "$dist_cli" "$dist_mcp" "$herdr_dist" "$console_dist"; do
    if [ ! -f "$output" ] || [ "$input" -nt "$output" ]; then
      workspace_stale=true
    fi
  done
done

# Protocol schema generation is part of the root build but its generator lives
# outside src, so include it explicitly in the freshness boundary.
if [ -f "$protocol_dist" ] && [ -d "$protocol_root/scripts" ] \
  && find "$protocol_root/scripts" -type f -name '*.mjs' -newer "$protocol_dist" -print -quit | grep -q .; then
  workspace_stale=true
fi

if [ "$workspace_stale" = false ]; then
  echo "agent-fabric dist fresh: $dist_cli"
  exit 0
fi

if [ ! -d "$agents_home/node_modules" ]; then
  echo "agent-fabric dist stale and node_modules missing; run 'npm ci' in $agents_home first" >&2
  exit 1
fi

echo "agent-fabric dist stale; rebuilding workspace"
cd "$agents_home"
npm run build

# The incremental build re-emits only changed outputs, so bump the wrapper
# freshness sentinels once the build has succeeded; otherwise an unchanged
# entrypoint can remain older than a dependency and force every warm to build.
touch "$protocol_dist" "$dist_cli" "$dist_mcp" "$herdr_dist" "$console_dist"
