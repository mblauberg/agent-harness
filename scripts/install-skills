#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
TARGET=""
CHECK=false

usage() {
  echo "usage: install-skills --target <global-skills-directory> [--check]" >&2
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target)
      [[ $# -ge 2 ]] || { usage; exit 2; }
      TARGET="$2"
      shift 2
      ;;
    --check)
      CHECK=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 2
      ;;
  esac
done

[[ -n "$TARGET" ]] || { usage; exit 2; }

# Claude installations may intentionally expose the canonical skill tree as
# one directory-level symlink. Preserve that layout instead of resolving the
# target into the source tree and treating source directories as unmanaged.
if [[ -L "$TARGET" ]] \
  && [[ "$(cd "$TARGET" && pwd -P)" == "$(cd "$ROOT/skills" && pwd -P)" ]]; then
  echo "skills existing=directory-link target=$TARGET"
  exit 0
fi

if [[ "$CHECK" == true ]]; then
  exec "$ROOT/scripts/manage_installation.py" check \
    --source "$ROOT/skills" \
    --target "$TARGET"
fi

exec "$ROOT/scripts/manage_installation.py" reconcile \
  --source "$ROOT/skills" \
  --target "$TARGET" \
  --renames "$ROOT/config/skill-renames.json" \
  --summary
