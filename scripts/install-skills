#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
TARGET=""

usage() {
  echo "usage: install-skills --target <global-skills-directory>" >&2
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target)
      [[ $# -ge 2 ]] || { usage; exit 2; }
      TARGET="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 2
      ;;
  esac
done

[[ -n "$TARGET" ]] || { usage; exit 2; }
exec "$ROOT/scripts/manage_installation.py" install \
  --source "$ROOT/skills" \
  --target "$TARGET" \
  --summary
