#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SOURCE="$ROOT/skills"
TARGET=""

usage() {
  echo "usage: install-skills --target <global-skills-directory>" >&2
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target)
      [[ $# -ge 2 ]] || { usage; exit 2; }
      TARGET="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 2
      ;;
  esac
done

[[ -n "$TARGET" ]] || { usage; exit 2; }
mkdir -p "$TARGET"

linked=0
existing=0
for manifest in "$SOURCE"/*/SKILL.md; do
  skill_dir="${manifest%/SKILL.md}"
  name="${skill_dir##*/}"
  destination="$TARGET/$name"
  if [[ -e "$destination" || -L "$destination" ]]; then
    existing=$((existing + 1))
    continue
  fi
  ln -s "$skill_dir" "$destination"
  linked=$((linked + 1))
done

echo "skills linked=$linked existing=$existing target=$TARGET"
