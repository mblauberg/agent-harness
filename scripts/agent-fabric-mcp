#!/bin/sh
# Launch the agent-fabric stdio MCP proxy defined by the public protocol contract.
# Requires AGENT_FABRIC_SOCKET_PATH and exactly one capability source:
# AGENT_FABRIC_SEAT plus AGENT_FABRIC_STATE_DIRECTORY (global project-aware
# registration), AGENT_FABRIC_CAPABILITY_FILE, or AGENT_FABRIC_CAPABILITY.
# Never registers itself with any client and never starts
# provider sessions; it only proxies stdio to the local daemon socket.
set -eu

SCRIPT_PATH=$0
while [ -L "$SCRIPT_PATH" ]; do
  LINK=$(readlink "$SCRIPT_PATH")
  case "$LINK" in
    /*) SCRIPT_PATH=$LINK ;;
    *) SCRIPT_PATH=$(dirname "$SCRIPT_PATH")/$LINK ;;
  esac
done
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)
HARNESS_ROOT=$(dirname -- "$SCRIPT_DIR")
AGENTS_ROOT=${AGENTS_HOME:-$HARNESS_ROOT}
case "$AGENTS_ROOT" in /*) ;; *) echo "AGENTS_HOME must be absolute" >&2; exit 2 ;; esac
FABRIC_ROOT="$AGENTS_ROOT/runtime/agent-fabric"
DIST_MCP="$FABRIC_ROOT/dist/mcp/main.js"

if [ -f "$DIST_MCP" ]; then
  if [ ! -d "$FABRIC_ROOT/src" ]; then
    echo "agent-fabric-mcp: Fabric source tree is unavailable: $FABRIC_ROOT/src" >&2
    exit 1
  fi
  if ! NEWER_SOURCE=$(find "$FABRIC_ROOT/src" -type f -name '*.ts' -newer "$DIST_MCP" -print); then
    echo "agent-fabric-mcp: Fabric source freshness check failed: $FABRIC_ROOT/src" >&2
    exit 1
  fi
  if [ -z "$NEWER_SOURCE" ]; then
    exec node "$DIST_MCP" "$@"
  fi
fi

# Source-tree fallback for development checkouts without a build.
exec node --import "$AGENTS_ROOT/node_modules/tsx/dist/loader.mjs" "$FABRIC_ROOT/src/mcp/main.ts" "$@"
