#!/bin/sh
set -eu

script_path=$0
while [ -L "$script_path" ]; do
  link=$(readlink "$script_path")
  case "$link" in
    /*) script_path=$link ;;
    *) script_path=$(dirname "$script_path")/$link ;;
  esac
done
script_dir=$(CDPATH= cd -- "$(dirname -- "$script_path")" && pwd)
agents_home=${AGENTS_HOME:-"$(dirname -- "$script_dir")"}
case "$agents_home" in /*) ;; *) echo "AGENTS_HOME must be absolute" >&2; exit 2 ;; esac
export AGENTS_HOME=$agents_home
package_root="$agents_home/runtime/agent-fabric"

dist_cli="$package_root/dist/cli/main.js"
if [ -f "$dist_cli" ] && ! find "$package_root/src" -type f -name '*.ts' -newer "$dist_cli" -print -quit | grep -q .; then
  exec node "$package_root/dist/cli/main.js" "$@"
fi

exec node --import "$package_root/node_modules/tsx/dist/loader.mjs" \
  "$package_root/src/cli/main.ts" "$@"
