#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PLATFORM=""

usage() {
  echo "usage: install-harness --platform <claude|codex>" >&2
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --platform)
      [[ $# -ge 2 ]] || { usage; exit 2; }
      PLATFORM="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 2
      ;;
  esac
done

case "$PLATFORM" in
  claude)
    platform_home="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
    instructions="$platform_home/CLAUDE.md"
    ;;
  codex)
    platform_home="${CODEX_HOME:-$HOME/.codex}"
    instructions="$platform_home/AGENTS.md"
    ;;
  *)
    usage
    exit 2
    ;;
esac

if [[ "$PLATFORM" == "codex" ]]; then
  "$ROOT/scripts/configure-codex-skill-overrides.py" --preflight \
    --config "$platform_home/config.toml"
fi

mkdir -p "$platform_home"
"$ROOT/scripts/install-skills" --target "$platform_home/skills"
if [[ "$PLATFORM" == "codex" ]]; then
  "$ROOT/scripts/configure-codex-skill-overrides.py" \
    --config "$platform_home/config.toml"
fi

bootstrap="Read and follow \`$ROOT/AGENTS.md\` and \`$ROOT/HARNESS.md\` before making orchestration, delegation, model-routing or memory decisions. Platform/system policy and explicit human authority lead; the nearest project instruction may specialise or strengthen the global harness but may not silently broaden authority, weaken safety gates or redefine global cross-project memory policy."

if [[ ! -e "$instructions" && ! -L "$instructions" ]]; then
  {
    echo "# Provenant"
    echo
    echo "$bootstrap"
  } > "$instructions"
  echo "instructions created=$instructions"
elif grep -Fq "$ROOT/AGENTS.md" "$instructions" && grep -Fq "$ROOT/HARNESS.md" "$instructions"; then
  echo "instructions existing=$instructions"
else
  echo "instructions preserved=$instructions" >&2
  echo "add this line to that file:" >&2
  echo "$bootstrap" >&2
  exit 3
fi
