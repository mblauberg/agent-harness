#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PLATFORM=""
MCP_CLIENTS="primary"

usage() {
  echo "usage: install-harness --platform <claude|codex> [--mcp-clients <primary|all>]" >&2
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --platform)
      [[ $# -ge 2 ]] || { usage; exit 2; }
      PLATFORM="$2"
      shift 2
      ;;
    --mcp-clients)
      [[ $# -ge 2 ]] || { usage; exit 2; }
      MCP_CLIENTS="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 2
      ;;
  esac
done

case "$PLATFORM" in
  claude)
    platform_home="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
    instructions="$platform_home/CLAUDE.md"
    ;;
  codex)
    platform_home="${CODEX_HOME:-$HOME/.codex}"
    instructions="$platform_home/AGENTS.md"
    ;;
  *)
    usage
    exit 2
    ;;
esac

case "$MCP_CLIENTS" in
  primary|all) ;;
  *) usage; exit 2 ;;
esac

provenant_bin_dir="${PROVENANT_BIN_DIR:-$HOME/.local/bin}"
provenant_command="$provenant_bin_dir/provenant"
provenant_source="$ROOT/scripts/provenant"

# Refuse a command collision before any installation mutation.
if [[ -e "$provenant_command" || -L "$provenant_command" ]]; then
  if [[ ! -L "$provenant_command" || "$(readlink "$provenant_command")" != "$provenant_source" ]]; then
    echo "provenant command collision=$provenant_command" >&2
    exit 3
  fi
fi

state_directory="${AGENT_FABRIC_STATE_DIRECTORY:-$HOME/.local/state/agent-harness/fabric}"
claude_mcp_config="${CLAUDE_MCP_CONFIG:-$HOME/.claude.json}"
mcp_platform="$PLATFORM"
if [[ "$MCP_CLIENTS" == "all" ]]; then
  mcp_platform="all"
fi
codex_mcp_config="${CODEX_MCP_CONFIG:-${CODEX_HOME:-$HOME/.codex}/config.toml}"
mcp_args=(
  --platform "$mcp_platform"
  --agents-home "$ROOT"
  --state-directory "$state_directory"
  --claude-config "$claude_mcp_config"
  --codex-config "$codex_mcp_config"
  --cursor-config "${CURSOR_MCP_CONFIG:-$HOME/.cursor/mcp.json}"
  --agy-config "${AGY_MCP_CONFIG:-$HOME/.gemini/config/mcp_config.json}"
  --kiro-config "${KIRO_MCP_CONFIG:-$HOME/.kiro/settings/mcp.json}"
  --opencode-config "${OPENCODE_MCP_CONFIG:-$HOME/.config/opencode/opencode.jsonc}"
)

"$ROOT/scripts/configure-agent-fabric-mcp.py" "${mcp_args[@]}" --preflight

if [[ "$PLATFORM" == "codex" ]]; then
  "$ROOT/scripts/configure-codex-skill-overrides.py" --preflight \
    --config "$platform_home/config.toml"
fi

mkdir -p "$provenant_bin_dir"
if [[ ! -L "$provenant_command" ]]; then
  ln -s "$provenant_source" "$provenant_command"
  echo "command installed=$provenant_command"
else
  echo "command existing=$provenant_command"
fi
case ":${PATH:-}:" in
  *":$provenant_bin_dir:"*) ;;
  *) echo "warning: $provenant_bin_dir is not on PATH" >&2 ;;
esac

mkdir -p "$platform_home"
"$ROOT/scripts/install-skills" --target "$platform_home/skills"
if [[ "$PLATFORM" == "claude" ]]; then
  "$ROOT/scripts/install-workflows" --target "$platform_home/workflows"
fi
if [[ "$PLATFORM" == "codex" ]]; then
  "$ROOT/scripts/configure-codex-skill-overrides.py" \
    --config "$platform_home/config.toml"
fi
"$ROOT/scripts/configure-agent-fabric-mcp.py" "${mcp_args[@]}"

bootstrap="Read and follow \`$ROOT/AGENTS.md\` and \`$ROOT/HARNESS.md\` before making orchestration, delegation, model-routing or memory decisions. Platform/system policy and explicit user authority lead; the nearest project instruction may specialise or strengthen the global harness but may not silently broaden authority, weaken safety gates or redefine global cross-project memory policy."

if [[ ! -e "$instructions" && ! -L "$instructions" ]]; then
  {
    echo "# Provenant"
    echo
    echo "$bootstrap"
  } > "$instructions"
  echo "instructions created=$instructions"
elif [[ -L "$instructions" && "$instructions" -ef "$ROOT/AGENTS.md" ]]; then
  echo "instructions existing=$instructions"
elif grep -Fq "$ROOT/AGENTS.md" "$instructions" && grep -Fq "$ROOT/HARNESS.md" "$instructions"; then
  echo "instructions existing=$instructions"
else
  echo "instructions preserved=$instructions" >&2
  echo "add this line to that file:" >&2
  echo "$bootstrap" >&2
  exit 3
fi
