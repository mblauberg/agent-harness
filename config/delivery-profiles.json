{
  "schema_version": 1,
  "profiles": {
    "software": {
      "artifact_types": ["source", "migration", "configuration", "documentation"],
      "required_evidence": {
        "deterministic": ["tests"],
        "judgement": ["code-review"]
      },
      "required_measures": {"outcome": ["functional-correctness"], "trajectory": ["verification-completion"]},
      "stochastic_policy": {"required": false, "minimum_repetitions": 2, "minimum_sample_size": 1},
      "security_surface_policy": ["source", "dependency", "auth-boundary", "destructive-boundary", "iac-container-config", "generated-artifact", "sensitive-data"],
      "boundary_checks": ["tests"],
      "evidence_policy": {"retention": ["risk-policy", "project-policy"], "redaction": "project-policy"},
      "release_semantics": "merge-deploy-or-publish",
      "observation_examples": ["availability", "error-rate", "task-success"]
    },
    "research": {
      "artifact_types": ["report", "dataset", "evidence-map"],
      "required_evidence": {
        "deterministic": ["source-coverage"],
        "judgement": ["source-quality"]
      },
      "required_measures": {"outcome": ["claim-support"], "trajectory": ["source-coverage-trajectory"]},
      "stochastic_policy": {"required": false, "minimum_repetitions": 2, "minimum_sample_size": 1},
      "security_surface_policy": ["generated-artifact", "sensitive-data"],
      "boundary_checks": ["source-coverage"],
      "evidence_policy": {"retention": ["risk-policy", "project-policy"], "redaction": "source-policy"},
      "release_semantics": "share-publish-or-use",
      "observation_examples": ["citation-audit", "use-follow-up"]
    },
    "analysis": {
      "artifact_types": ["report", "model", "table", "visualisation"],
      "required_evidence": {
        "deterministic": ["recalculation"],
        "judgement": ["interpretation"]
      },
      "required_measures": {"outcome": ["decision-utility"], "trajectory": ["assumption-validation"]},
      "stochastic_policy": {"required": false, "minimum_repetitions": 2, "minimum_sample_size": 1},
      "security_surface_policy": ["generated-artifact", "sensitive-data"],
      "boundary_checks": ["recalculation"],
      "evidence_policy": {"retention": ["risk-policy", "project-policy"], "redaction": "source-policy"},
      "release_semantics": "share-or-use",
      "observation_examples": ["decision-follow-up", "assumption-review"]
    },
    "document": {
      "artifact_types": ["markdown", "docx", "pdf", "slides", "spreadsheet", "html", "interactive-document"],
      "required_evidence": {
        "deterministic": ["render"],
        "judgement": ["audience-fit"]
      },
      "conditional_evidence": {
        "html": {"deterministic": ["link-integrity"], "judgement": []},
        "interactive-document": {"deterministic": ["link-integrity", "interaction-smoke"], "judgement": []}
      },
      "required_measures": {"outcome": ["audience-readiness"], "trajectory": ["render-quality"]},
      "stochastic_policy": {"required": false, "minimum_repetitions": 2, "minimum_sample_size": 1},
      "security_surface_policy": ["source", "generated-artifact", "sensitive-data"],
      "boundary_checks": ["render"],
      "evidence_policy": {"retention": ["risk-policy", "project-policy"], "redaction": "document-policy"},
      "release_semantics": "send-file-or-publish",
      "observation_examples": ["recipient-confirmation", "registry-acceptance"]
    },
    "agent-product": {
      "artifact_types": ["prompt", "tool", "policy", "evaluation-set", "deployment-config"],
      "required_evidence": {
        "deterministic": ["tests", "permission-check"],
        "judgement": ["agent-product-review"]
      },
      "required_measures": {"outcome": ["task-success"], "trajectory": ["policy-compliance"]},
      "stochastic_policy": {"required": false, "required_for_artifact_types": ["prompt", "tool", "policy", "evaluation-set"], "minimum_repetitions": 3, "minimum_sample_size": 10},
      "security_surface_policy": ["source", "dependency", "auth-boundary", "destructive-boundary", "iac-container-config", "generated-artifact", "sensitive-data", "agent-tools", "inter-agent"],
      "boundary_checks": ["tests", "permission-check"],
      "evidence_policy": {"retention": ["risk-policy", "project-policy"], "redaction": "project-policy"},
      "release_semantics": "staged-activation",
      "observation_examples": ["task-success", "policy-violations", "tool-failures"]
    }
  },
  "artifact_type_surfaces": {
    "source": ["source"],
    "migration": ["source", "destructive-boundary"],
    "configuration": ["source", "iac-container-config"],
    "documentation": ["generated-artifact"],
    "report": ["generated-artifact"],
    "dataset": ["generated-artifact", "sensitive-data"],
    "evidence-map": ["generated-artifact"],
    "model": ["generated-artifact"],
    "table": ["generated-artifact"],
    "visualisation": ["generated-artifact"],
    "markdown": ["generated-artifact"],
    "docx": ["generated-artifact"],
    "pdf": ["generated-artifact"],
    "slides": ["generated-artifact"],
    "spreadsheet": ["generated-artifact"],
    "html": ["generated-artifact"],
    "interactive-document": ["generated-artifact", "source"],
    "prompt": ["agent-tools"],
    "tool": ["source", "agent-tools"],
    "policy": ["source", "agent-tools"],
    "evaluation-set": ["generated-artifact"],
    "deployment-config": ["source", "iac-container-config", "agent-tools"]
  },
  "high_stakes_overlay": {"required": {
    "source_authority": {"evidence_kinds": ["human", "deterministic"], "gate": "high-stakes:source-authority"},
    "privacy": {"evidence_kinds": ["deterministic"], "gate": "high-stakes:privacy"},
    "qualified_domain_review": {"evidence_kinds": ["human", "judgement"], "gate": "high-stakes:qualified-domain-review"},
    "explicit_human_action_gate": {"evidence_kinds": ["human"], "gate": "high-stakes:explicit-human-action"}
  }}
}
