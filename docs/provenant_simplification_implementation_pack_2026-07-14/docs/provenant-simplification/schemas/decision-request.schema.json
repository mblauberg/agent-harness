{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://provenant.local/schemas/decision-request.schema.json",
  "title": "Fabric decision request",
  "description": "Persisted contract; class-tagged per ADR-0007 (03_MINIMAL_CONTRACTS.md sections 1.3/11).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_id",
    "mode",
    "decision_class",
    "scope",
    "question",
    "options",
    "recommendation",
    "evidence_refs",
    "status",
    "created_at",
    "retention_class"
  ],
  "$defs": {
    "retention_class": {
      "description": "ADR-0007 retention class (03_MINIMAL_CONTRACTS.md section 1.3). Validated on admission; an absent or unknown class is refused, never defaulted.",
      "enum": [
        "ephemeral",
        "operational",
        "evidence",
        "durable-knowledge",
        "sensitive"
      ]
    }
  },
  "properties": {
    "schema_version": {
      "const": 1
    },
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "notice",
        "soft",
        "hard"
      ]
    },
    "decision_class": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "project_session_id": {
          "type": "string"
        },
        "run_id": {
          "type": "string"
        },
        "issue_id": {
          "type": "string"
        },
        "task_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "recommendation": {
      "type": "string"
    },
    "default_action": {
      "type": [
        "string",
        "null"
      ]
    },
    "override_until": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "cut_point": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "council_record_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "related_prs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "status": {
      "enum": [
        "open",
        "default-applied",
        "human-overrode",
        "chair-resolved",
        "council-resolved",
        "superseded",
        "closed"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "resolved_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "resolution_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "retention_class": {
      "description": "Default class for a DecisionRequest is evidence; a record carrying secret-bearing content is reclassified sensitive. The value is always explicit.",
      "$ref": "#/$defs/retention_class"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "mode": {
            "const": "soft"
          }
        }
      },
      "then": {
        "required": [
          "default_action",
          "cut_point"
        ]
      }
    }
  ]
}
