{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://provenant.local/schemas/document-frontmatter.schema.json",
  "title": "Canonical project document frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "kind",
    "status",
    "owner",
    "canonical_keys",
    "supersedes",
    "related"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9.-]+$"
    },
    "kind": {
      "enum": [
        "architecture",
        "adr",
        "spec",
        "runbook",
        "research",
        "threat-model",
        "governance",
        "archive-index"
      ]
    },
    "status": {
      "enum": [
        "draft",
        "current",
        "superseded",
        "retired"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "canonical_keys": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9._-]+$"
      },
      "uniqueItems": true
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "superseded_by": {
      "type": [
        "string",
        "null"
      ]
    },
    "related": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "adrs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "specs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "runbooks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "reviewed_at": {
      "type": "string",
      "format": "date"
    },
    "retention": {
      "enum": [
        "ephemeral",
        "operational",
        "evidence",
        "durable-knowledge",
        "sensitive"
      ]
    },
    "retention_reason": {
      "type": "string"
    },
    "maximum_lines": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "spec"
          }
        }
      },
      "then": {
        "required": [
          "maximum_lines"
        ],
        "properties": {
          "maximum_lines": {
            "const": 1000
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "superseded"
          }
        }
      },
      "then": {
        "required": [
          "superseded_by"
        ]
      }
    }
  ]
}
