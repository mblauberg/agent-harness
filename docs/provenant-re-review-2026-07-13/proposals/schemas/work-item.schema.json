{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://provenant.local/schemas/work-item.schema.json",
  "title": "Provenant vertical-slice work item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "title",
    "state",
    "outcome",
    "non_goals",
    "acceptance",
    "links",
    "dependencies",
    "conflict_keys",
    "risk",
    "authority",
    "evidence",
    "review",
    "effects"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "enum": [
        "proposed",
        "scoped",
        "ready",
        "claimed",
        "executing",
        "review",
        "rework",
        "accepted",
        "done",
        "blocked",
        "paused-decision",
        "paused-budget",
        "retired"
      ]
    },
    "outcome": {
      "type": "string",
      "minLength": 1
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "criterion"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "criterion": {
            "type": "string",
            "minLength": 1
          },
          "evidence_ref": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "specs",
        "adrs"
      ],
      "properties": {
        "specs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "adrs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "parent": {
          "type": [
            "string",
            "null"
          ]
        },
        "prs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "conflict_keys": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tier",
        "factors"
      ],
      "properties": {
        "tier": {
          "enum": [
            "routine",
            "substantial",
            "crucial",
            "terminal"
          ]
        },
        "factors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "charter_digest",
        "write_paths",
        "prohibited_actions",
        "expires_at"
      ],
      "properties": {
        "charter_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "write_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "prohibited_actions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deterministic"
      ],
      "properties": {
        "deterministic": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "judgement": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "live": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class"
      ],
      "properties": {
        "class": {
          "enum": [
            "native",
            "cross-primary",
            "specialist",
            "human-merge"
          ]
        },
        "required_families": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "effects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed"
      ],
      "properties": {
        "allowed": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "pr_strategy": {
      "enum": [
        "independent",
        "stacked",
        "consolidated",
        "direct-commit",
        "undecided"
      ]
    }
  }
}
