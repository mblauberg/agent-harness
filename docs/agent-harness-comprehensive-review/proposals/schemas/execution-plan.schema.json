{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/execution-plan.schema.json",
  "title": "Harness execution plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "planId",
    "scopeDigest",
    "authorityDigest",
    "chair",
    "agents",
    "tasks",
    "integration",
    "verification",
    "review",
    "budgets",
    "replanConditions"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "planId": {
      "type": "string",
      "minLength": 1
    },
    "scopeDigest": {
      "type": "string",
      "pattern": "^sha256:"
    },
    "authorityDigest": {
      "type": "string",
      "pattern": "^sha256:"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "chair": {
      "$ref": "#/$defs/agent"
    },
    "agents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/agent"
      },
      "uniqueItems": true
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/task"
      }
    },
    "integration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ownerAgentId",
        "strategy"
      ],
      "properties": {
        "ownerAgentId": {
          "type": "string"
        },
        "strategy": {
          "enum": [
            "serial-apply",
            "merge",
            "cherry-pick",
            "artefact-synthesis",
            "none"
          ]
        },
        "targetWorktree": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deterministicGates",
        "cleanCheckout"
      ],
      "properties": {
        "deterministicGates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cleanCheckout": {
          "type": "boolean"
        },
        "liveGates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policyClass",
        "reviewers",
        "repairCycles"
      ],
      "properties": {
        "policyClass": {
          "enum": [
            "trivial",
            "substantial",
            "highRisk",
            "crucialEffect"
          ]
        },
        "reviewers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reviewer"
          }
        },
        "repairCycles": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "replanConditions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "externalEffects": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agentId",
        "role",
        "provider",
        "family",
        "routeIntent",
        "effort",
        "authorityProfile"
      ],
      "properties": {
        "agentId": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "family": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "routeIntent": {
          "enum": [
            "flagship",
            "workhorse",
            "scout"
          ]
        },
        "effort": {
          "type": "string",
          "minLength": 1
        },
        "authorityProfile": {
          "type": "string",
          "minLength": 1
        },
        "parentAgentId": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "taskId",
        "title",
        "ownerAgentId",
        "dependencies",
        "writeScope",
        "returnContract",
        "completionCriteria",
        "stopConditions"
      ],
      "properties": {
        "taskId": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "ownerAgentId": {
          "type": "string",
          "minLength": 1
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "writeScope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "paths"
          ],
          "properties": {
            "mode": {
              "enum": [
                "none",
                "artefact-only",
                "worktree"
              ]
            },
            "paths": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "worktree": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "returnContract": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "completionCriteria": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "stopConditions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agentId",
        "independence",
        "lens"
      ],
      "properties": {
        "agentId": {
          "type": "string"
        },
        "independence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "freshContext",
            "differentAuthor",
            "familyDistinct"
          ],
          "properties": {
            "freshContext": {
              "type": "boolean"
            },
            "differentAuthor": {
              "type": "boolean"
            },
            "familyDistinct": {
              "type": "boolean"
            }
          }
        },
        "lens": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
