{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/backlog-item.schema.json",
  "title": "Approved harness backlog item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "itemId",
    "title",
    "state",
    "outcome",
    "acceptanceCriteria",
    "dependencies",
    "value",
    "risk",
    "authorityTemplate",
    "approval",
    "execution",
    "freshness"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "itemId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "enum": [
        "proposed",
        "scoped",
        "approved",
        "ready",
        "claimed",
        "executing",
        "review",
        "rework",
        "accepted",
        "done",
        "blocked",
        "retired",
        "expired",
        "paused-decision",
        "paused-budget",
        "failed-invariant",
        "quarantined"
      ]
    },
    "outcome": {
      "type": "string",
      "minLength": 1
    },
    "nonGoals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "value": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "rationale"
      ],
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "factors"
      ],
      "properties": {
        "level": {
          "enum": [
            "low",
            "medium",
            "high",
            "crucial"
          ]
        },
        "factors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "authorityTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repositories",
        "writeScopes",
        "profiles",
        "externalEffects"
      ],
      "properties": {
        "repositories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "writeScopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "profiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "externalEffects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "scopeDigest"
      ],
      "properties": {
        "status": {
          "enum": [
            "pending",
            "approved",
            "revoked"
          ]
        },
        "approvedBy": {
          "type": [
            "string",
            "null"
          ]
        },
        "approvedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "expiresAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "scopeDigest": {
          "type": "string",
          "pattern": "^sha256:"
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiredEvidence",
        "budgets",
        "retryLimit",
        "stopConditions"
      ],
      "properties": {
        "requiredEvidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "budgets": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "retryLimit": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "stopConditions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeRevision",
        "lastReviewedAt"
      ],
      "properties": {
        "scopeRevision": {
          "type": "integer",
          "minimum": 1
        },
        "lastReviewedAt": {
          "type": "string",
          "format": "date-time"
        },
        "maximumAgeDays": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "claim": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "runId",
        "claimedAt",
        "heartbeatAt"
      ],
      "properties": {
        "runId": {
          "type": "string"
        },
        "claimedAt": {
          "type": "string",
          "format": "date-time"
        },
        "heartbeatAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
