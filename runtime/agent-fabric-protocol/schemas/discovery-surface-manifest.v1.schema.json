{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "hostId",
    "hostVersion",
    "providerProfile",
    "rawNativeMode",
    "principalScopeDigest",
    "permissionProfileDigest",
    "negotiatedFeatureSetDigest",
    "rendererVersion",
    "bootstrapText",
    "skills",
    "tools",
    "agentCommands",
    "nativePreambleText",
    "bootstrapDigest",
    "skillCatalogueDigest",
    "toolRegistryDigest",
    "agentCommandRegistryDigest",
    "nativePreambleDigest"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "hostId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "hostVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "providerProfile": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "rawNativeMode": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        {
          "type": "null"
        }
      ]
    },
    "principalScopeDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "permissionProfileDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "negotiatedFeatureSetDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "rendererVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "bootstrapText": {
      "type": "string",
      "minLength": 0,
      "maxLength": 1048576,
      "x-minUtf8Bytes": 0,
      "x-maxUtf8Bytes": 1048576
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 4096
          }
        }
      },
      "minItems": 0,
      "maxItems": 4096
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "description",
          "inputSchema"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 4096
          },
          "inputSchema": {
            "$ref": "#/$defs/boundedJsonValue"
          }
        }
      },
      "minItems": 0,
      "maxItems": 4096
    },
    "agentCommands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 4096
          }
        }
      },
      "minItems": 0,
      "maxItems": 4096
    },
    "nativePreambleText": {
      "type": "string",
      "minLength": 0,
      "maxLength": 1048576,
      "x-minUtf8Bytes": 0,
      "x-maxUtf8Bytes": 1048576
    },
    "bootstrapDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "skillCatalogueDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "toolRegistryDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "agentCommandRegistryDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "nativePreambleDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
