{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "code",
    "evidenceDigest"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "code": {
      "type": "string",
      "enum": [
        "INVALID_REQUEST",
        "UNAUTHENTICATED",
        "BUNDLE_MISMATCH",
        "NOT_LISTED",
        "CROSS_BUNDLE",
        "BUDGET_EXHAUSTED",
        "RESULT_TOO_LARGE",
        "INTEGRITY_FAILURE"
      ]
    },
    "evidenceDigest": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
