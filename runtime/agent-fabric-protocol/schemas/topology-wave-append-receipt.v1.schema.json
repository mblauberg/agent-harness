{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "commandId",
    "status",
    "priorPlanRef",
    "planRef",
    "pointer",
    "receiptDigest"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "commandId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "status": {
      "const": "appended"
    },
    "priorPlanRef": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schemaVersion",
            "projectSessionId",
            "coordinationRunId",
            "taskId",
            "waveId",
            "waveRevision",
            "planDigest"
          ],
          "properties": {
            "schemaVersion": {
              "const": 1
            },
            "projectSessionId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "coordinationRunId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "taskId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "waveId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "waveRevision": {
              "type": "integer",
              "minimum": 1
            },
            "planDigest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            }
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "planRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "projectSessionId",
        "coordinationRunId",
        "taskId",
        "waveId",
        "waveRevision",
        "planDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "projectSessionId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "coordinationRunId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "taskId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "waveId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "waveRevision": {
          "type": "integer",
          "minimum": 1
        },
        "planDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "pointer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "projectSessionId",
        "coordinationRunId",
        "taskId",
        "waveId",
        "waveRevision",
        "planDigest",
        "revision"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "projectSessionId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "coordinationRunId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "taskId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "waveId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "waveRevision": {
          "type": "integer",
          "minimum": 1
        },
        "planDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "receiptDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "x-topologyAppendReceiptCorrelated": true,
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
