{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidenceId",
    "targetGeneration",
    "slot",
    "taskId",
    "actionRef",
    "terminalSequence",
    "terminalKind",
    "verdict",
    "answerSafety",
    "providerAnswerDigest",
    "terminalResultDigest",
    "reviewResultDigest",
    "providerFailureCode",
    "providerFailureDigest",
    "routeReceiptDigest",
    "routeObservationDigest",
    "actualRouteIdentityDigest",
    "finalPromptDigest",
    "adapterId",
    "endpointProvider",
    "providerFamily",
    "model",
    "bundleDigest",
    "coverageDigest",
    "profileDigest",
    "priorHeadGeneration",
    "newHeadGeneration",
    "attemptGeneration",
    "priorEvidenceId",
    "priorOpenFindingSet",
    "reportedResolvedFindingDigests",
    "acceptedResolvedFindingDigests",
    "findingSet",
    "newOpenFindingSet",
    "repairRequiredFindingSet",
    "findingWindow",
    "readCoverageDigest",
    "coverageSummary",
    "reviewerFamilyRelation",
    "certificationBasisAtTerminal",
    "mutationReceiptDigest"
  ],
  "properties": {
    "evidenceId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "targetGeneration": {
      "type": "integer",
      "minimum": 1
    },
    "slot": {
      "type": "string",
      "enum": [
        "native",
        "other-primary",
        "cursor-grok",
        "agy-gemini"
      ]
    },
    "taskId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "actionRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapterId",
        "actionId"
      ],
      "properties": {
        "adapterId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "actionId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        }
      }
    },
    "terminalSequence": {
      "type": "integer",
      "minimum": 1
    },
    "terminalKind": {
      "type": "string",
      "enum": [
        "safe-answer",
        "unusable-answer"
      ]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "CLEAN",
        "FINDINGS",
        "UNUSABLE"
      ]
    },
    "answerSafety": {
      "type": "string",
      "enum": [
        "safe",
        "unusable"
      ]
    },
    "providerAnswerDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "terminalResultDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "reviewResultDigest": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "providerFailureCode": {
      "const": null
    },
    "providerFailureDigest": {
      "const": null
    },
    "routeReceiptDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "routeObservationDigest": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "actualRouteIdentityDigest": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "finalPromptDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "adapterId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "endpointProvider": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "providerFamily": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "model": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "bundleDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "coverageDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "profileDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "priorHeadGeneration": {
      "type": "integer",
      "minimum": 0
    },
    "newHeadGeneration": {
      "type": "integer",
      "minimum": 1
    },
    "attemptGeneration": {
      "type": "integer",
      "minimum": 1
    },
    "priorEvidenceId": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        {
          "type": "null"
        }
      ]
    },
    "priorOpenFindingSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "findingSetDigest",
        "findingCount",
        "pageDigests"
      ],
      "properties": {
        "findingSetDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "findingCount": {
          "type": "integer",
          "minimum": 0
        },
        "pageDigests": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "minItems": 0,
          "maxItems": 16384,
          "uniqueItems": true
        }
      }
    },
    "reportedResolvedFindingDigests": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^sha256:[a-f0-9]{64}$"
      },
      "minItems": 0,
      "maxItems": 16384,
      "uniqueItems": true
    },
    "acceptedResolvedFindingDigests": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^sha256:[a-f0-9]{64}$"
      },
      "minItems": 0,
      "maxItems": 16384,
      "uniqueItems": true
    },
    "findingSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "findingSetDigest",
        "findingCount",
        "pageDigests"
      ],
      "properties": {
        "findingSetDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "findingCount": {
          "type": "integer",
          "minimum": 0
        },
        "pageDigests": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "minItems": 0,
          "maxItems": 16384,
          "uniqueItems": true
        }
      }
    },
    "newOpenFindingSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "findingSetDigest",
        "findingCount",
        "pageDigests"
      ],
      "properties": {
        "findingSetDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "findingCount": {
          "type": "integer",
          "minimum": 0
        },
        "pageDigests": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "minItems": 0,
          "maxItems": 16384,
          "uniqueItems": true
        }
      }
    },
    "repairRequiredFindingSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "findingSetDigest",
        "findingCount",
        "pageDigests"
      ],
      "properties": {
        "findingSetDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "findingCount": {
          "type": "integer",
          "minimum": 0
        },
        "pageDigests": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "minItems": 0,
          "maxItems": 16384,
          "uniqueItems": true
        }
      }
    },
    "findingWindow": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "maximumNewFindings",
            "maximumNewFindingBytes",
            "capacityReservationDigest"
          ],
          "properties": {
            "mode": {
              "const": "normal"
            },
            "maximumNewFindings": {
              "const": 32
            },
            "maximumNewFindingBytes": {
              "type": "integer",
              "minimum": 1
            },
            "capacityReservationDigest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "maximumNewFindings",
            "maximumNewFindingBytes",
            "capacityReservationDigest"
          ],
          "properties": {
            "mode": {
              "const": "resolution-only"
            },
            "maximumNewFindings": {
              "const": 0
            },
            "maximumNewFindingBytes": {
              "const": 0
            },
            "capacityReservationDigest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            }
          }
        }
      ]
    },
    "readCoverageDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "coverageSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "mandatoryComplete",
        "groups",
        "byteComplete"
      ],
      "properties": {
        "mode": {
          "const": "manifest-complete-risk-directed"
        },
        "mandatoryComplete": {
          "type": "boolean"
        },
        "groups": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "groupId",
              "totalCount",
              "readCount",
              "unreadCount",
              "unreadObjectSetDigest"
            ],
            "properties": {
              "groupId": {
                "type": "string",
                "enum": [
                  "security-auth",
                  "protocol-schema",
                  "persistence-migration",
                  "provider-adapter",
                  "console-ui",
                  "tests-evaluations",
                  "documentation",
                  "generated-other"
                ]
              },
              "totalCount": {
                "type": "integer",
                "minimum": 0
              },
              "readCount": {
                "type": "integer",
                "minimum": 0
              },
              "unreadCount": {
                "type": "integer",
                "minimum": 0
              },
              "unreadObjectSetDigest": {
                "type": "string",
                "pattern": "^sha256:[a-f0-9]{64}$"
              }
            }
          },
          "minItems": 0,
          "maxItems": 8,
          "uniqueItems": true
        },
        "byteComplete": {
          "type": "boolean"
        }
      },
      "x-coverageGroupsOrdered": true
    },
    "reviewerFamilyRelation": {
      "type": "string",
      "enum": [
        "same-family-exempt",
        "distinct-family-proved",
        "same-family-forbidden",
        "family-unproved"
      ]
    },
    "certificationBasisAtTerminal": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "actionBindingGeneration",
            "activeBindingGeneration",
            "terminalSequence",
            "bindingChainDigest"
          ],
          "properties": {
            "kind": {
              "const": "active-binding"
            },
            "actionBindingGeneration": {
              "type": "integer",
              "minimum": 1
            },
            "activeBindingGeneration": {
              "type": "integer",
              "minimum": 1
            },
            "terminalSequence": {
              "type": "integer",
              "minimum": 1
            },
            "bindingChainDigest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "actionBindingGeneration",
            "firstSuccessorBindingGeneration",
            "activeBindingGeneration",
            "terminalSequence",
            "certificationCutSequence",
            "certificationCutCustodyRef",
            "certificationCutDigest",
            "bindingChainDigest"
          ],
          "properties": {
            "kind": {
              "const": "predecessor-cut"
            },
            "actionBindingGeneration": {
              "type": "integer",
              "minimum": 1
            },
            "firstSuccessorBindingGeneration": {
              "type": "integer",
              "minimum": 1
            },
            "activeBindingGeneration": {
              "type": "integer",
              "minimum": 1
            },
            "terminalSequence": {
              "type": "integer",
              "minimum": 1
            },
            "certificationCutSequence": {
              "type": "integer",
              "minimum": 0
            },
            "certificationCutCustodyRef": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "schemaVersion",
                "runId",
                "agentId",
                "custodyId",
                "custodyRevision"
              ],
              "properties": {
                "schemaVersion": {
                  "const": 1
                },
                "runId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "x-minUtf8Bytes": 1,
                  "x-maxUtf8Bytes": 256
                },
                "agentId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "x-minUtf8Bytes": 1,
                  "x-maxUtf8Bytes": 256
                },
                "custodyId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "x-minUtf8Bytes": 1,
                  "x-maxUtf8Bytes": 256
                },
                "custodyRevision": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            },
            "certificationCutDigest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            },
            "bindingChainDigest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "actionBindingGeneration",
            "firstSuccessorBindingGeneration",
            "activeBindingGeneration",
            "terminalSequence",
            "certificationCutSequence",
            "certificationCutCustodyRef",
            "certificationCutDigest",
            "bindingChainDigest"
          ],
          "properties": {
            "kind": {
              "const": "post-cut"
            },
            "actionBindingGeneration": {
              "type": "integer",
              "minimum": 1
            },
            "firstSuccessorBindingGeneration": {
              "type": "integer",
              "minimum": 1
            },
            "activeBindingGeneration": {
              "type": "integer",
              "minimum": 1
            },
            "terminalSequence": {
              "type": "integer",
              "minimum": 1
            },
            "certificationCutSequence": {
              "type": "integer",
              "minimum": 0
            },
            "certificationCutCustodyRef": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "schemaVersion",
                "runId",
                "agentId",
                "custodyId",
                "custodyRevision"
              ],
              "properties": {
                "schemaVersion": {
                  "const": 1
                },
                "runId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "x-minUtf8Bytes": 1,
                  "x-maxUtf8Bytes": 256
                },
                "agentId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "x-minUtf8Bytes": 1,
                  "x-maxUtf8Bytes": 256
                },
                "custodyId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "x-minUtf8Bytes": 1,
                  "x-maxUtf8Bytes": 256
                },
                "custodyRevision": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            },
            "certificationCutDigest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            },
            "bindingChainDigest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            }
          }
        }
      ],
      "x-reviewCertificationBasisCorrelated": true
    },
    "mutationReceiptDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "x-reviewEvidenceCorrelated": true,
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
