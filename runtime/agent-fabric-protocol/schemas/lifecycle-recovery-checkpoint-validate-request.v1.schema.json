{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "projectSessionId",
    "coordinationRunId",
    "agentId",
    "source",
    "checkpointArtifactRef",
    "expectedSessionRevision",
    "expectedSessionGeneration",
    "expectedRunRevision",
    "expectedAgentRevision",
    "expectedSourceRevision",
    "gateId",
    "expectedGateRevision",
    "expectedGateStatus"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "projectSessionId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "coordinationRunId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "agentId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "source": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "custodyRef"
          ],
          "properties": {
            "kind": {
              "const": "custody"
            },
            "custodyRef": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "schemaVersion",
                "runId",
                "agentId",
                "custodyId",
                "custodyRevision"
              ],
              "properties": {
                "schemaVersion": {
                  "const": 1
                },
                "runId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "x-minUtf8Bytes": 1,
                  "x-maxUtf8Bytes": 256
                },
                "agentId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "x-minUtf8Bytes": 1,
                  "x-maxUtf8Bytes": 256
                },
                "custodyId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "x-minUtf8Bytes": 1,
                  "x-maxUtf8Bytes": 256
                },
                "custodyRevision": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "oldCustodyRef",
            "generationLossRef",
            "lossKind",
            "oldProviderSessionRef",
            "newProviderSessionRef",
            "oldProviderGeneration",
            "newProviderGeneration",
            "oldContextRevision",
            "newContextRevision",
            "sourceBridgeRef",
            "sourceCapabilityHash",
            "checkpointState",
            "checkpointRef",
            "checkpointDigest",
            "lossEvidenceDigest"
          ],
          "properties": {
            "kind": {
              "const": "generation-loss"
            },
            "oldCustodyRef": {
              "const": null
            },
            "generationLossRef": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "schemaVersion",
                "runId",
                "agentId",
                "generationLossId",
                "generationLossRevision"
              ],
              "properties": {
                "schemaVersion": {
                  "const": 1
                },
                "runId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "x-minUtf8Bytes": 1,
                  "x-maxUtf8Bytes": 256
                },
                "agentId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "x-minUtf8Bytes": 1,
                  "x-maxUtf8Bytes": 256
                },
                "generationLossId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "x-minUtf8Bytes": 1,
                  "x-maxUtf8Bytes": 256
                },
                "generationLossRevision": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            },
            "lossKind": {
              "type": "string",
              "enum": [
                "generation-advance",
                "context-advance"
              ]
            },
            "oldProviderSessionRef": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "newProviderSessionRef": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "oldProviderGeneration": {
              "type": "integer",
              "minimum": 1
            },
            "newProviderGeneration": {
              "type": "integer",
              "minimum": 1
            },
            "oldContextRevision": {
              "oneOf": [
                {
                  "type": "integer",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ]
            },
            "newContextRevision": {
              "type": "integer",
              "minimum": 0
            },
            "sourceBridgeRef": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "bridgeId",
                "bridgeRevision"
              ],
              "properties": {
                "bridgeId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "x-minUtf8Bytes": 1,
                  "x-maxUtf8Bytes": 256
                },
                "bridgeRevision": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            },
            "sourceCapabilityHash": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            },
            "checkpointState": {
              "type": "string",
              "enum": [
                "absent",
                "invalid",
                "last-validated"
              ]
            },
            "checkpointRef": {
              "oneOf": [
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "checkpointId",
                    "checkpointRevision"
                  ],
                  "properties": {
                    "checkpointId": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 256,
                      "x-minUtf8Bytes": 1,
                      "x-maxUtf8Bytes": 256
                    },
                    "checkpointRevision": {
                      "type": "integer",
                      "minimum": 1
                    }
                  }
                },
                {
                  "type": "null"
                }
              ]
            },
            "checkpointDigest": {
              "oneOf": [
                {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                },
                {
                  "type": "null"
                }
              ]
            },
            "lossEvidenceDigest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            }
          },
          "x-lifecycleRecoverySourceCorrelated": true
        }
      ]
    },
    "checkpointArtifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "digest"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*[\\\\*?\\[\\]{}]).+$"
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "expectedSessionRevision": {
      "type": "integer",
      "minimum": 1
    },
    "expectedSessionGeneration": {
      "type": "integer",
      "minimum": 1
    },
    "expectedRunRevision": {
      "type": "integer",
      "minimum": 1
    },
    "expectedAgentRevision": {
      "type": "integer",
      "minimum": 1
    },
    "expectedSourceRevision": {
      "type": "integer",
      "minimum": 1
    },
    "gateId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "expectedGateRevision": {
      "type": "integer",
      "minimum": 1
    },
    "expectedGateStatus": {
      "const": "approved"
    }
  },
  "x-lifecycleCheckpointValidateCorrelated": true,
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
