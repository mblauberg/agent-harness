{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "actionRef",
        "terminalSequence",
        "terminalKind",
        "providerAnswerDigest",
        "reviewResultDigest",
        "answerSafety",
        "readCoverageDigest",
        "coverageSummaryDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "actionRef": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "adapterId",
            "actionId"
          ],
          "properties": {
            "adapterId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "actionId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            }
          }
        },
        "terminalSequence": {
          "type": "integer",
          "minimum": 1
        },
        "terminalKind": {
          "const": "safe-answer"
        },
        "providerAnswerDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "reviewResultDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "answerSafety": {
          "const": "safe"
        },
        "readCoverageDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "coverageSummaryDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "actionRef",
        "terminalSequence",
        "terminalKind",
        "providerAnswerDigest",
        "reviewResultDigest",
        "answerSafety",
        "readCoverageDigest",
        "coverageSummaryDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "actionRef": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "adapterId",
            "actionId"
          ],
          "properties": {
            "adapterId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "actionId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            }
          }
        },
        "terminalSequence": {
          "type": "integer",
          "minimum": 1
        },
        "terminalKind": {
          "const": "unusable-answer"
        },
        "providerAnswerDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "reviewResultDigest": {
          "const": null
        },
        "answerSafety": {
          "const": "unusable"
        },
        "readCoverageDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "coverageSummaryDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "actionRef",
        "terminalSequence",
        "terminalKind",
        "providerFailureCode",
        "providerFailureDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "actionRef": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "adapterId",
            "actionId"
          ],
          "properties": {
            "adapterId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "actionId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            }
          }
        },
        "terminalSequence": {
          "type": "integer",
          "minimum": 1
        },
        "terminalKind": {
          "const": "provider-terminal-failure"
        },
        "providerFailureCode": {
          "type": "string",
          "enum": [
            "max-turns-exhausted",
            "provider-rejected",
            "terminal-no-answer",
            "adapter-terminal-failure"
          ]
        },
        "providerFailureDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "actionRef",
        "terminalSequence",
        "terminalKind",
        "noEffectEvidenceDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "actionRef": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "adapterId",
            "actionId"
          ],
          "properties": {
            "adapterId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "actionId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            }
          }
        },
        "terminalSequence": {
          "type": "integer",
          "minimum": 1
        },
        "terminalKind": {
          "const": "terminal-no-effect"
        },
        "noEffectEvidenceDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "actionRef",
        "terminalSequence",
        "terminalKind",
        "integrityEvidenceDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "actionRef": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "adapterId",
            "actionId"
          ],
          "properties": {
            "adapterId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "actionId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            }
          }
        },
        "terminalSequence": {
          "type": "integer",
          "minimum": 1
        },
        "terminalKind": {
          "const": "integrity-terminal"
        },
        "integrityEvidenceDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "actionRef",
        "terminalSequence",
        "terminalKind",
        "retirementEvidenceDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "actionRef": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "adapterId",
            "actionId"
          ],
          "properties": {
            "adapterId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "actionId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            }
          }
        },
        "terminalSequence": {
          "type": "integer",
          "minimum": 1
        },
        "terminalKind": {
          "const": "retired-unknown"
        },
        "retirementEvidenceDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    }
  ],
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
