{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "taskId",
    "waveId",
    "dependencies",
    "decomposability",
    "topology",
    "stageOwners",
    "writePartitions",
    "contention",
    "budget",
    "stopConditions",
    "state",
    "rationaleRef"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "taskId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "waveId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "dependencyTaskId",
          "requiredState",
          "evidenceRef"
        ],
        "properties": {
          "dependencyTaskId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          },
          "requiredState": {
            "type": "string",
            "enum": [
              "ready",
              "completed"
            ]
          },
          "evidenceRef": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          }
        }
      },
      "minItems": 0,
      "maxItems": 1024,
      "uniqueItems": true
    },
    "decomposability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "evidenceRef"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "atomic",
            "decomposable",
            "conditionally-decomposable"
          ]
        },
        "evidenceRef": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        }
      }
    },
    "topology": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executionShape",
        "mode",
        "maximumConcurrentAgents"
      ],
      "properties": {
        "executionShape": {
          "type": "string",
          "enum": [
            "single-owner",
            "fabric-explicit",
            "host-native"
          ]
        },
        "mode": {
          "type": "string",
          "enum": [
            "serial",
            "parallel",
            "fan-out-fan-in",
            "dynamic"
          ]
        },
        "maximumConcurrentAgents": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "stageOwners": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stageId",
          "taskId",
          "ownerAgentId",
          "writePartitionId"
        ],
        "properties": {
          "stageId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          },
          "taskId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          },
          "ownerAgentId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          },
          "writePartitionId": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 256,
                "x-minUtf8Bytes": 1,
                "x-maxUtf8Bytes": 256
              },
              {
                "type": "null"
              }
            ]
          }
        }
      },
      "minItems": 1,
      "maxItems": 1024,
      "uniqueItems": true
    },
    "writePartitions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "partitionId",
          "ownerAgentId",
          "mode",
          "pathSetDigest",
          "authorityRef"
        ],
        "properties": {
          "partitionId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          },
          "ownerAgentId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          },
          "mode": {
            "type": "string",
            "enum": [
              "exclusive-write",
              "shared-read"
            ]
          },
          "pathSetDigest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "authorityRef": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          }
        }
      },
      "minItems": 0,
      "maxItems": 1024,
      "uniqueItems": true
    },
    "contention": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "serializationOwnerAgentId",
        "evidenceRef"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "serialized",
            "disjoint-partitions"
          ]
        },
        "serializationOwnerAgentId": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            {
              "type": "null"
            }
          ]
        },
        "evidenceRef": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "providerTurns",
        "toolCalls",
        "wallClockSeconds",
        "maximumParallelAgents"
      ],
      "properties": {
        "providerTurns": {
          "type": "integer",
          "minimum": 0
        },
        "toolCalls": {
          "type": "integer",
          "minimum": 0
        },
        "wallClockSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "maximumParallelAgents": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "stopConditions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "conditionId",
          "kind",
          "predicateRef"
        ],
        "properties": {
          "conditionId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          },
          "kind": {
            "type": "string",
            "enum": [
              "objective-complete",
              "gate-failed",
              "budget-exhausted",
              "human-gate"
            ]
          },
          "predicateRef": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          }
        }
      },
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true
    },
    "state": {
      "type": "string",
      "enum": [
        "proposed",
        "approved",
        "started",
        "completed",
        "superseded",
        "cancelled"
      ]
    },
    "rationaleRef": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    }
  },
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
