{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "evidenceId",
    "actionRef",
    "terminalSequence",
    "targetGeneration",
    "slot",
    "attemptGeneration",
    "priorHeadGeneration",
    "newHeadGeneration",
    "priorEvidenceId",
    "terminalResultDigest",
    "terminalInputDigest",
    "reportedResolvedSetDigest",
    "acceptedResolvedSetDigest",
    "findingSetDigest",
    "newOpenSetDigest",
    "repairRequiredSetDigest",
    "readCoverageDigest",
    "coverageSummaryDigest",
    "findingWindowDigest",
    "certificationBasisAtTerminalDigest",
    "mutationReceiptDigest"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "evidenceId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "actionRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapterId",
        "actionId"
      ],
      "properties": {
        "adapterId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "actionId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        }
      }
    },
    "terminalSequence": {
      "type": "integer",
      "minimum": 1
    },
    "targetGeneration": {
      "type": "integer",
      "minimum": 1
    },
    "slot": {
      "type": "string",
      "enum": [
        "native",
        "other-primary",
        "cursor-grok",
        "agy-gemini"
      ]
    },
    "attemptGeneration": {
      "type": "integer",
      "minimum": 1
    },
    "priorHeadGeneration": {
      "type": "integer",
      "minimum": 0
    },
    "newHeadGeneration": {
      "type": "integer",
      "minimum": 1
    },
    "priorEvidenceId": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        {
          "type": "null"
        }
      ]
    },
    "terminalResultDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "terminalInputDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "reportedResolvedSetDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "acceptedResolvedSetDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "findingSetDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "newOpenSetDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "repairRequiredSetDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "readCoverageDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "coverageSummaryDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "findingWindowDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "certificationBasisAtTerminalDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "mutationReceiptDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "x-reviewEvidenceMutationReceiptCorrelated": true,
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
