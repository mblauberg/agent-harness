    "disclosure": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "level"
          ],
          "properties": {
            "level": {
              "const": "allowed"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "level",
            "scopes"
          ],
          "properties": {
            "level": {
              "const": "scoped"
            },
            "scopes": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "local",
                  "approved-provider",
                  "external"
                ]
              },
              "minItems": 1,
              "maxItems": 2,
              "uniqueItems": true
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "level"
          ],
          "properties": {
            "level": {
              "const": "forbidden"
            }
          }
        }
      ]
    },
    "secrets": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "access"
          ],
          "properties": {
            "access": {
              "const": "none"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "access",
            "references"
          ],
          "properties": {
            "access": {
              "const": "use-without-disclosure"
            },
            "references": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 256,
                "x-minUtf8Bytes": 1,
