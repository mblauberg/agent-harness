      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "toolEgress"
          ],
          "properties": {
            "toolEgress": {
              "const": "none"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "toolEgress",
            "allowedHosts"
          ],
          "properties": {
            "toolEgress": {
              "const": "allowlist"
            },
            "allowedHosts": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 253,
                "x-minUtf8Bytes": 1,
                "x-maxUtf8Bytes": 253,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9.:-]{0,252}$"
              },
              "minItems": 1,
              "maxItems": 256,
              "uniqueItems": true
            }
          }
        }
