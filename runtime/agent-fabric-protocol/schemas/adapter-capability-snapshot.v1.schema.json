{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "snapshotId",
    "snapshotGeneration",
    "adapterId",
    "adapterContractDigest",
    "hostId",
    "hostVersion",
    "source",
    "observedAt",
    "expiresAt",
    "capabilities",
    "capabilityBodyDigest",
    "snapshotDigest"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "snapshotId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "snapshotGeneration": {
      "type": "integer",
      "minimum": 1
    },
    "adapterId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "adapterContractDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "hostId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "hostVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "source": {
      "type": "string",
      "enum": [
        "runtime-discovery",
        "version-pinned-conformance",
        "unavailable"
      ]
    },
    "observedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "capabilities": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "modelCatalog",
            "context",
            "orchestration",
            "safety"
          ],
          "properties": {
            "kind": {
              "const": "available"
            },
            "modelCatalog": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "family",
                  "model",
                  "effort",
                  "nativeModeNormalizations"
                ],
                "properties": {
                  "family": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "x-minUtf8Bytes": 1,
                    "x-maxUtf8Bytes": 256
                  },
                  "model": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "x-minUtf8Bytes": 1,
                    "x-maxUtf8Bytes": 256
                  },
                  "effort": {
                    "oneOf": [
                      {
                        "type": "object",
                        "additionalProperties": false,
                        "required": [
                          "kind",
                          "normalizations"
                        ],
                        "properties": {
                          "kind": {
                            "const": "applied"
                          },
                          "normalizations": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "additionalProperties": false,
                              "required": [
                                "rawProviderEffort",
                                "normalizedReasoningEffort"
                              ],
                              "properties": {
                                "rawProviderEffort": {
                                  "type": "string",
                                  "minLength": 1,
                                  "maxLength": 256,
                                  "x-minUtf8Bytes": 1,
                                  "x-maxUtf8Bytes": 256
                                },
                                "normalizedReasoningEffort": {
                                  "type": "string",
                                  "enum": [
                                    "none",
                                    "low",
                                    "medium",
                                    "high",
                                    "xhigh",
                                    "max"
                                  ]
                                }
                              }
                            },
                            "minItems": 1,
                            "maxItems": 64,
                            "uniqueItems": true
                          }
                        }
                      },
                      {
                        "type": "object",
                        "additionalProperties": false,
                        "required": [
                          "kind"
                        ],
                        "properties": {
                          "kind": {
                            "const": "inapplicable"
                          }
                        }
                      }
                    ]
                  },
                  "nativeModeNormalizations": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "rawNativeMode",
                        "orchestrationMode"
                      ],
                      "properties": {
                        "rawNativeMode": {
                          "oneOf": [
                            {
                              "type": "string",
                              "minLength": 1,
                              "maxLength": 256,
                              "x-minUtf8Bytes": 1,
                              "x-maxUtf8Bytes": 256
                            },
                            {
                              "type": "null"
                            }
                          ]
                        },
                        "orchestrationMode": {
                          "type": "string",
                          "enum": [
                            "single",
                            "native-subagents",
                            "dynamic-workflow",
                            "provider-multi-agent"
                          ]
                        }
                      }
                    },
                    "minItems": 1,
                    "maxItems": 64,
                    "uniqueItems": true
                  }
                }
              },
              "minItems": 1,
              "maxItems": 256,
              "uniqueItems": true
            },
            "context": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "reporting",
                "compactInPlace",
                "freshSession",
                "boundaryInjection"
              ],
              "properties": {
                "reporting": {
                  "type": "string",
                  "enum": [
                    "reported",
                    "estimated",
                    "unavailable"
                  ]
                },
                "compactInPlace": {
                  "oneOf": [
                    {
                      "const": true
                    },
                    {
                      "const": false
                    },
                    {
                      "const": "unknown"
                    }
                  ]
                },
                "freshSession": {
                  "oneOf": [
                    {
                      "const": true
                    },
                    {
                      "const": false
                    },
                    {
                      "const": "unknown"
                    }
                  ]
                },
                "boundaryInjection": {
                  "type": "string",
                  "enum": [
                    "verified",
                    "unverified",
                    "unavailable"
                  ]
                }
              }
            },
            "orchestration": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "nativeSubagents",
                "maxDepth",
                "maxConcurrency"
              ],
              "properties": {
                "nativeSubagents": {
                  "type": "string",
                  "enum": [
                    "none",
                    "bounded",
                    "recursive",
                    "unknown"
                  ]
                },
                "maxDepth": {
                  "oneOf": [
                    {
                      "type": "integer",
                      "minimum": 0
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "maxConcurrency": {
                  "oneOf": [
                    {
                      "type": "integer",
                      "minimum": 1
                    },
                    {
                      "type": "null"
                    }
                  ]
                }
              }
            },
            "safety": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "enforcedReadOnly",
                "permissionSource"
              ],
              "properties": {
                "enforcedReadOnly": {
                  "oneOf": [
                    {
                      "const": true
                    },
                    {
                      "const": false
                    },
                    {
                      "const": "unknown"
                    }
                  ]
                },
                "permissionSource": {
                  "type": "string",
                  "enum": [
                    "adapter",
                    "host",
                    "config-overlay",
                    "unknown"
                  ]
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "reason"
          ],
          "properties": {
            "kind": {
              "const": "unavailable"
            },
            "reason": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 512
            }
          }
        }
      ]
    },
    "capabilityBodyDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "snapshotDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "x-adapterCapabilitySnapshotCorrelated": true,
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
