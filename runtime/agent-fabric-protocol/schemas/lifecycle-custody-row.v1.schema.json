{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "sourceKind",
        "agentId",
        "custodyId",
        "custodyRevision",
        "actionRef",
        "sourceProviderGeneration",
        "sourcePrincipalGeneration",
        "sourceBridgeGeneration",
        "targetProviderGeneration",
        "targetPrincipalGeneration",
        "targetBridgeGeneration",
        "checkpointDigest",
        "state",
        "disposition",
        "terminalEvidenceDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "sourceKind": {
          "const": "custody"
        },
        "agentId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "custodyId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "custodyRevision": {
          "type": "integer",
          "minimum": 1
        },
        "actionRef": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "adapterId",
            "actionId"
          ],
          "properties": {
            "adapterId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "actionId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            }
          }
        },
        "sourceProviderGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "sourcePrincipalGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "sourceBridgeGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "targetProviderGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "targetPrincipalGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "targetBridgeGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "checkpointDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "state": {
          "type": "string",
          "enum": [
            "awaiting-boundary",
            "prepared",
            "dispatched",
            "accepted",
            "ambiguous"
          ]
        },
        "disposition": {
          "const": null
        },
        "terminalEvidenceDigest": {
          "const": null
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "sourceKind",
        "agentId",
        "custodyId",
        "custodyRevision",
        "actionRef",
        "sourceProviderGeneration",
        "sourcePrincipalGeneration",
        "sourceBridgeGeneration",
        "targetProviderGeneration",
        "targetPrincipalGeneration",
        "targetBridgeGeneration",
        "checkpointDigest",
        "state",
        "disposition",
        "terminalEvidenceDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "sourceKind": {
          "const": "custody"
        },
        "agentId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "custodyId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "custodyRevision": {
          "type": "integer",
          "minimum": 1
        },
        "actionRef": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "adapterId",
            "actionId"
          ],
          "properties": {
            "adapterId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "actionId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            }
          }
        },
        "sourceProviderGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "sourcePrincipalGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "sourceBridgeGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "targetProviderGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "targetPrincipalGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "targetBridgeGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "checkpointDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "state": {
          "type": "string",
          "enum": [
            "provider-terminal",
            "committing"
          ]
        },
        "disposition": {
          "const": null
        },
        "terminalEvidenceDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "sourceKind",
        "agentId",
        "custodyId",
        "custodyRevision",
        "actionRef",
        "sourceProviderGeneration",
        "sourcePrincipalGeneration",
        "sourceBridgeGeneration",
        "targetProviderGeneration",
        "targetPrincipalGeneration",
        "targetBridgeGeneration",
        "checkpointDigest",
        "state",
        "disposition",
        "terminalEvidenceDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "sourceKind": {
          "const": "custody"
        },
        "agentId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "custodyId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "custodyRevision": {
          "type": "integer",
          "minimum": 1
        },
        "actionRef": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "adapterId",
            "actionId"
          ],
          "properties": {
            "adapterId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "actionId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            }
          }
        },
        "sourceProviderGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "sourcePrincipalGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "sourceBridgeGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "targetProviderGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "targetPrincipalGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "targetBridgeGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "checkpointDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "state": {
          "const": "finalized"
        },
        "disposition": {
          "type": "string",
          "enum": [
            "adopted",
            "no-effect",
            "quarantined",
            "superseded",
            "abandoned"
          ]
        },
        "terminalEvidenceDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    }
  ],
  "x-lifecycleCustodyCorrelated": true,
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
