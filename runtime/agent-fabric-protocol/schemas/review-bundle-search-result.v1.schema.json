{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bundleDigest",
    "entries",
    "resultDigest"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "bundleDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "objectDigest",
          "offset",
          "rawByteLength",
          "encoding",
          "snippet"
        ],
        "properties": {
          "objectDigest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "offset": {
            "type": "integer",
            "minimum": 0
          },
          "rawByteLength": {
            "type": "integer",
            "minimum": 1
          },
          "encoding": {
            "const": "base64"
          },
          "snippet": {
            "type": "string",
            "minLength": 0,
            "maxLength": 87384,
            "x-minUtf8Bytes": 0,
            "x-maxUtf8Bytes": 87384,
            "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
          }
        }
      },
      "minItems": 0,
      "maxItems": 100,
      "uniqueItems": true
    },
    "resultDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "x-maxCanonicalJsonBytes": 65536,
  "x-searchEntriesCanonical": true,
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
