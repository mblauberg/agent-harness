{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "accepted",
    "revision",
    "state",
    "phase",
    "progress",
    "terminal"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "accepted": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "preparationId",
        "ownerCommandId",
        "inputDigest",
        "projectSessionId",
        "coordinationRunId",
        "taskId",
        "expectedTargetGeneration",
        "reservedTargetGeneration",
        "reservedBundleGeneration",
        "deliveryManifestRef",
        "state",
        "acceptedReceiptDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "preparationId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "ownerCommandId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "inputDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "projectSessionId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "coordinationRunId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "taskId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "expectedTargetGeneration": {
          "type": "integer",
          "minimum": 0
        },
        "reservedTargetGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "reservedBundleGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "deliveryManifestRef": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "state": {
          "const": "prepared"
        },
        "acceptedReceiptDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "state": {
      "type": "string",
      "enum": [
        "prepared",
        "building",
        "built",
        "succeeded",
        "conflicted",
        "failed"
      ]
    },
    "phase": {
      "type": "string",
      "enum": [
        "Preparing",
        "Building",
        "Committing",
        "Succeeded",
        "Conflicted",
        "Failed"
      ]
    },
    "progress": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "const": "phase-only"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "unit",
            "completed",
            "total",
            "planDigest"
          ],
          "properties": {
            "kind": {
              "const": "finite"
            },
            "unit": {
              "const": "verified-build-items"
            },
            "completed": {
              "type": "integer",
              "minimum": 0
            },
            "total": {
              "type": "integer",
              "minimum": 1
            },
            "planDigest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            }
          }
        }
      ]
    },
    "terminal": {
      "oneOf": [
        {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kind",
                "targetRef"
              ],
              "properties": {
                "kind": {
                  "const": "succeeded"
                },
                "targetRef": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kind",
                "code",
                "evidenceDigest"
              ],
              "properties": {
                "kind": {
                  "const": "conflicted"
                },
                "code": {
                  "type": "string",
                  "enum": [
                    "target-generation-changed",
                    "chair-binding-changed",
                    "task-or-authority-changed",
                    "delivery-basis-changed",
                    "repository-source-changed",
                    "profile-changed",
                    "predecessor-head-changed",
                    "predecessor-action-nonterminal"
                  ]
                },
                "evidenceDigest": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kind",
                "code",
                "evidenceDigest"
              ],
              "properties": {
                "kind": {
                  "const": "failed"
                },
                "code": {
                  "type": "string",
                  "enum": [
                    "bundle-too-large",
                    "unsupported-repository-state",
                    "source-read-failed",
                    "content-integrity-failed",
                    "certifying-capability-unavailable"
                  ]
                },
                "evidenceDigest": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                }
              }
            }
          ]
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "x-reviewPreparationCorrelated": true,
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
