{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "routeRequestDigest",
    "routeReceiptDigest",
    "adapterId",
    "adapterContractDigest",
    "providerFamily",
    "resolvedModel",
    "requestedEffort",
    "resolvedEffort",
    "targetGeneration",
    "slot",
    "reviewedArtifactRef",
    "publicationLineageDigest",
    "bundleDigest",
    "manifestRootDigest",
    "coverageDigest",
    "bundleSearchIndexDigest",
    "riskReadMapDigest",
    "mandatoryReadSetDigest",
    "finalPromptDigest",
    "targetChair",
    "profileDigest",
    "slotHeadGeneration",
    "attemptGeneration"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "routeRequestDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "routeReceiptDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "adapterId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "adapterContractDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "providerFamily": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "resolvedModel": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "requestedEffort": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        {
          "type": "null"
        }
      ]
    },
    "resolvedEffort": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "const": "applied"
            },
            "value": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "const": "inapplicable"
            }
          }
        }
      ]
    },
    "targetGeneration": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "slot": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "native",
            "other-primary",
            "cursor-grok",
            "agy-gemini"
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "reviewedArtifactRef": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        {
          "type": "null"
        }
      ]
    },
    "publicationLineageDigest": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "bundleDigest": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "manifestRootDigest": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "coverageDigest": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "bundleSearchIndexDigest": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "riskReadMapDigest": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "mandatoryReadSetDigest": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "finalPromptDigest": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "targetChair": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "agentId",
            "bindingGeneration",
            "principalGeneration",
            "chairLeaseGeneration",
            "providerSessionGeneration",
            "bridgeGeneration",
            "adapterId",
            "adapterContractDigest",
            "modelFamily",
            "model",
            "routeReceiptDigest"
          ],
          "properties": {
            "agentId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "bindingGeneration": {
              "type": "integer",
              "minimum": 1
            },
            "principalGeneration": {
              "type": "integer",
              "minimum": 1
            },
            "chairLeaseGeneration": {
              "type": "integer",
              "minimum": 1
            },
            "providerSessionGeneration": {
              "type": "integer",
              "minimum": 1
            },
            "bridgeGeneration": {
              "type": "integer",
              "minimum": 1
            },
            "adapterId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "adapterContractDigest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            },
            "modelFamily": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "model": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "routeReceiptDigest": {
              "oneOf": [
                {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "profileDigest": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "slotHeadGeneration": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "attemptGeneration": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
