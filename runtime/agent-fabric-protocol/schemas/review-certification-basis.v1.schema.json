{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "actionBindingGeneration",
        "activeBindingGeneration",
        "terminalSequence",
        "bindingChainDigest"
      ],
      "properties": {
        "kind": {
          "const": "active-binding"
        },
        "actionBindingGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "activeBindingGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "terminalSequence": {
          "type": "integer",
          "minimum": 1
        },
        "bindingChainDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "actionBindingGeneration",
        "firstSuccessorBindingGeneration",
        "activeBindingGeneration",
        "terminalSequence",
        "certificationCutSequence",
        "certificationCutCustodyRef",
        "certificationCutDigest",
        "bindingChainDigest"
      ],
      "properties": {
        "kind": {
          "const": "predecessor-cut"
        },
        "actionBindingGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "firstSuccessorBindingGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "activeBindingGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "terminalSequence": {
          "type": "integer",
          "minimum": 1
        },
        "certificationCutSequence": {
          "type": "integer",
          "minimum": 0
        },
        "certificationCutCustodyRef": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schemaVersion",
            "runId",
            "agentId",
            "custodyId",
            "custodyRevision"
          ],
          "properties": {
            "schemaVersion": {
              "const": 1
            },
            "runId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "agentId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "custodyId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "custodyRevision": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "certificationCutDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "bindingChainDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "actionBindingGeneration",
        "firstSuccessorBindingGeneration",
        "activeBindingGeneration",
        "terminalSequence",
        "certificationCutSequence",
        "certificationCutCustodyRef",
        "certificationCutDigest",
        "bindingChainDigest"
      ],
      "properties": {
        "kind": {
          "const": "post-cut"
        },
        "actionBindingGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "firstSuccessorBindingGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "activeBindingGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "terminalSequence": {
          "type": "integer",
          "minimum": 1
        },
        "certificationCutSequence": {
          "type": "integer",
          "minimum": 0
        },
        "certificationCutCustodyRef": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schemaVersion",
            "runId",
            "agentId",
            "custodyId",
            "custodyRevision"
          ],
          "properties": {
            "schemaVersion": {
              "const": 1
            },
            "runId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "agentId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "custodyId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "custodyRevision": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "certificationCutDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "bindingChainDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    }
  ],
  "x-reviewCertificationBasisCorrelated": true,
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
