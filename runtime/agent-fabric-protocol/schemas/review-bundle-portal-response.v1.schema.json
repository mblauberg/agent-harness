{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jsonrpc",
        "id",
        "result"
      ],
      "properties": {
        "jsonrpc": {
          "const": "2.0"
        },
        "id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 2147483647
            },
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 64,
              "pattern": "^[A-Za-z0-9._:-]{1,64}$"
            }
          ]
        },
        "result": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "schemaVersion",
                "bundleDigest",
                "payloadDigest",
                "offset",
                "rawByteLength",
                "mediaType",
                "encoding",
                "payload",
                "resultDigest",
                "kind",
                "parentDigest",
                "ordinal"
              ],
              "properties": {
                "schemaVersion": {
                  "const": 1
                },
                "bundleDigest": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                },
                "payloadDigest": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                },
                "offset": {
                  "type": "integer",
                  "minimum": 0
                },
                "rawByteLength": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 65536
                },
                "mediaType": {
                  "type": "string",
                  "enum": [
                    "application/octet-stream",
                    "application/vnd.agent-fabric.review-bundle-root.v1+json",
                    "application/vnd.agent-fabric.review-bundle-body.v1+json",
                    "application/vnd.agent-fabric.review-diff.v1+json",
                    "application/vnd.agent-fabric.review-finding-page.v1+json",
                    "application/vnd.agent-fabric.review-finding-set.v1+json"
                  ]
                },
                "encoding": {
                  "const": "base64"
                },
                "payload": {
                  "type": "string",
                  "minLength": 0,
                  "maxLength": 87384,
                  "x-minUtf8Bytes": 0,
                  "x-maxUtf8Bytes": 87384,
                  "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
                },
                "resultDigest": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                },
                "kind": {
                  "const": "manifest-root"
                },
                "parentDigest": {
                  "const": null
                },
                "ordinal": {
                  "const": 0
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "schemaVersion",
                "bundleDigest",
                "payloadDigest",
                "offset",
                "rawByteLength",
                "mediaType",
                "encoding",
                "payload",
                "resultDigest",
                "kind",
                "parentDigest",
                "ordinal"
              ],
              "properties": {
                "schemaVersion": {
                  "const": 1
                },
                "bundleDigest": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                },
                "payloadDigest": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                },
                "offset": {
                  "type": "integer",
                  "minimum": 0
                },
                "rawByteLength": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 65536
                },
                "mediaType": {
                  "type": "string",
                  "enum": [
                    "application/octet-stream",
                    "application/vnd.agent-fabric.review-bundle-root.v1+json",
                    "application/vnd.agent-fabric.review-bundle-body.v1+json",
                    "application/vnd.agent-fabric.review-diff.v1+json",
                    "application/vnd.agent-fabric.review-finding-page.v1+json",
                    "application/vnd.agent-fabric.review-finding-set.v1+json"
                  ]
                },
                "encoding": {
                  "const": "base64"
                },
                "payload": {
                  "type": "string",
                  "minLength": 0,
                  "maxLength": 87384,
                  "x-minUtf8Bytes": 0,
                  "x-maxUtf8Bytes": 87384,
                  "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
                },
                "resultDigest": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                },
                "kind": {
                  "type": "string",
                  "enum": [
                    "manifest-body-page",
                    "object",
                    "chunk"
                  ]
                },
                "parentDigest": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                },
                "ordinal": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          ],
          "x-base64LengthMatches": true
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jsonrpc",
        "id",
        "result"
      ],
      "properties": {
        "jsonrpc": {
          "const": "2.0"
        },
        "id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 2147483647
            },
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 64,
              "pattern": "^[A-Za-z0-9._:-]{1,64}$"
            }
          ]
        },
        "result": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schemaVersion",
            "bundleDigest",
            "entries",
            "resultDigest"
          ],
          "properties": {
            "schemaVersion": {
              "const": 1
            },
            "bundleDigest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            },
            "entries": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "objectDigest",
                  "offset",
                  "rawByteLength",
                  "encoding",
                  "snippet"
                ],
                "properties": {
                  "objectDigest": {
                    "type": "string",
                    "pattern": "^sha256:[a-f0-9]{64}$"
                  },
                  "offset": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "rawByteLength": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "encoding": {
                    "const": "base64"
                  },
                  "snippet": {
                    "type": "string",
                    "minLength": 0,
                    "maxLength": 87384,
                    "x-minUtf8Bytes": 0,
                    "x-maxUtf8Bytes": 87384,
                    "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
                  }
                }
              },
              "minItems": 0,
              "maxItems": 100,
              "uniqueItems": true
            },
            "resultDigest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            }
          },
          "x-maxCanonicalJsonBytes": 65536,
          "x-searchEntriesCanonical": true
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jsonrpc",
        "id",
        "error"
      ],
      "properties": {
        "jsonrpc": {
          "const": "2.0"
        },
        "id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 2147483647
            },
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 64,
              "pattern": "^[A-Za-z0-9._:-]{1,64}$"
            }
          ]
        },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schemaVersion",
            "code",
            "evidenceDigest"
          ],
          "properties": {
            "schemaVersion": {
              "const": 1
            },
            "code": {
              "type": "string",
              "enum": [
                "INVALID_REQUEST",
                "UNAUTHENTICATED",
                "BUNDLE_MISMATCH",
                "NOT_LISTED",
                "CROSS_BUNDLE",
                "BUDGET_EXHAUSTED",
                "RESULT_TOO_LARGE",
                "INTEGRITY_FAILURE"
              ]
            },
            "evidenceDigest": {
              "oneOf": [
                {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        }
      }
    }
  ],
  "x-reviewPortalResponseBound": true,
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
