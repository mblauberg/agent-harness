{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "projectSessionId",
    "coordinationRunId",
    "action",
    "agentId",
    "taskId",
    "taskRevision",
    "lifecycle",
    "custodyRef",
    "actionRef",
    "checkpointDigest",
    "openWorkSetDigest",
    "deliveryCutWatermark",
    "predecessorTurnSetDigest",
    "sourceProviderGeneration",
    "sourcePrincipalGeneration",
    "sourceBridgeGeneration",
    "targetProviderGeneration",
    "targetPrincipalGeneration",
    "targetBridgeGeneration",
    "acceptedReceiptDigest"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "kind": {
      "const": "accepted-suspended"
    },
    "projectSessionId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "coordinationRunId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "action": {
      "type": "string",
      "enum": [
        "compact",
        "rotate"
      ]
    },
    "agentId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "taskId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "taskRevision": {
      "type": "integer",
      "minimum": 1
    },
    "lifecycle": {
      "const": "suspended"
    },
    "custodyRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "runId",
        "agentId",
        "custodyId",
        "custodyRevision"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "runId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "agentId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "custodyId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "custodyRevision": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "actionRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapterId",
        "actionId"
      ],
      "properties": {
        "adapterId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "actionId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        }
      }
    },
    "checkpointDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "openWorkSetDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "deliveryCutWatermark": {
      "type": "integer",
      "minimum": 0
    },
    "predecessorTurnSetDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "sourceProviderGeneration": {
      "type": "integer",
      "minimum": 1
    },
    "sourcePrincipalGeneration": {
      "type": "integer",
      "minimum": 1
    },
    "sourceBridgeGeneration": {
      "type": "integer",
      "minimum": 1
    },
    "targetProviderGeneration": {
      "type": "integer",
      "minimum": 1
    },
    "targetPrincipalGeneration": {
      "type": "integer",
      "minimum": 1
    },
    "targetBridgeGeneration": {
      "type": "integer",
      "minimum": 1
    },
    "acceptedReceiptDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "x-lifecycleAcceptedSuspendedCorrelated": true,
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
