{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "bundleDigest",
        "payloadDigest",
        "offset",
        "rawByteLength",
        "mediaType",
        "encoding",
        "payload",
        "resultDigest",
        "kind",
        "parentDigest",
        "ordinal"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "bundleDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "payloadDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "offset": {
          "type": "integer",
          "minimum": 0
        },
        "rawByteLength": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65536
        },
        "mediaType": {
          "type": "string",
          "enum": [
            "application/octet-stream",
            "application/vnd.agent-fabric.review-bundle-root.v1+json",
            "application/vnd.agent-fabric.review-bundle-body.v1+json",
            "application/vnd.agent-fabric.review-diff.v1+json",
            "application/vnd.agent-fabric.review-finding-page.v1+json",
            "application/vnd.agent-fabric.review-finding-set.v1+json"
          ]
        },
        "encoding": {
          "const": "base64"
        },
        "payload": {
          "type": "string",
          "minLength": 0,
          "maxLength": 87384,
          "x-minUtf8Bytes": 0,
          "x-maxUtf8Bytes": 87384,
          "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
        },
        "resultDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "kind": {
          "const": "manifest-root"
        },
        "parentDigest": {
          "const": null
        },
        "ordinal": {
          "const": 0
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "bundleDigest",
        "payloadDigest",
        "offset",
        "rawByteLength",
        "mediaType",
        "encoding",
        "payload",
        "resultDigest",
        "kind",
        "parentDigest",
        "ordinal"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "bundleDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "payloadDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "offset": {
          "type": "integer",
          "minimum": 0
        },
        "rawByteLength": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65536
        },
        "mediaType": {
          "type": "string",
          "enum": [
            "application/octet-stream",
            "application/vnd.agent-fabric.review-bundle-root.v1+json",
            "application/vnd.agent-fabric.review-bundle-body.v1+json",
            "application/vnd.agent-fabric.review-diff.v1+json",
            "application/vnd.agent-fabric.review-finding-page.v1+json",
            "application/vnd.agent-fabric.review-finding-set.v1+json"
          ]
        },
        "encoding": {
          "const": "base64"
        },
        "payload": {
          "type": "string",
          "minLength": 0,
          "maxLength": 87384,
          "x-minUtf8Bytes": 0,
          "x-maxUtf8Bytes": 87384,
          "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
        },
        "resultDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "manifest-body-page",
            "object",
            "chunk"
          ]
        },
        "parentDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "ordinal": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  ],
  "x-base64LengthMatches": true,
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
