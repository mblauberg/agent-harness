{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "hostId",
    "hostVersion",
    "adapterId",
    "adapterContractDigest",
    "endpointProvider",
    "family",
    "model",
    "resolvedEffort",
    "normalizedReasoningEffort",
    "rawNativeMode",
    "orchestrationMode",
    "capabilityBodyDigest",
    "requestedConfigurationDigest",
    "effectiveConfigurationDigest",
    "permissionProfileDigest",
    "discoverySurfaceRef",
    "routePolicyRevision",
    "harnessRevision",
    "harnessDigest",
    "contextPolicyRevision",
    "contextPolicyDigest",
    "topologyWavePlanRef"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "hostId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "hostVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "adapterId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "adapterContractDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "endpointProvider": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "family": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "model": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "resolvedEffort": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "value"
          ],
          "properties": {
            "kind": {
              "const": "applied"
            },
            "value": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "const": "inapplicable"
            }
          }
        }
      ]
    },
    "normalizedReasoningEffort": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "none",
            "low",
            "medium",
            "high",
            "xhigh",
            "max"
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "rawNativeMode": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        {
          "type": "null"
        }
      ]
    },
    "orchestrationMode": {
      "type": "string",
      "enum": [
        "single",
        "native-subagents",
        "dynamic-workflow",
        "provider-multi-agent"
      ]
    },
    "capabilityBodyDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "requestedConfigurationDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "effectiveConfigurationDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "permissionProfileDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "discoverySurfaceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidenceId",
        "evidenceRevision",
        "artifactRef",
        "hostId",
        "hostVersion",
        "providerProfile",
        "rawNativeMode",
        "evidenceKind",
        "producer",
        "manifestDigest"
      ],
      "properties": {
        "evidenceId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "evidenceRevision": {
          "type": "integer",
          "minimum": 1
        },
        "artifactRef": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "digest"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4096,
              "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*[\\\\*?\\[\\]{}]).+$"
            },
            "digest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            }
          }
        },
        "hostId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "hostVersion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "providerProfile": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "rawNativeMode": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            {
              "type": "null"
            }
          ]
        },
        "evidenceKind": {
          "const": "discovery-surface.v1"
        },
        "producer": {
          "const": "fabric-daemon"
        },
        "manifestDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "routePolicyRevision": {
      "type": "integer",
      "minimum": 1
    },
    "harnessRevision": {
      "type": "integer",
      "minimum": 1
    },
    "harnessDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "contextPolicyRevision": {
      "type": "integer",
      "minimum": 1
    },
    "contextPolicyDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "topologyWavePlanRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "projectSessionId",
        "coordinationRunId",
        "taskId",
        "waveId",
        "waveRevision",
        "planDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "projectSessionId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "coordinationRunId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "taskId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "waveId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        "waveRevision": {
          "type": "integer",
          "minimum": 1
        },
        "planDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    }
  },
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
