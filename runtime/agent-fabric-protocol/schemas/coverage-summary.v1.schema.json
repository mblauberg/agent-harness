{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mode",
    "mandatoryComplete",
    "groups",
    "byteComplete"
  ],
  "properties": {
    "mode": {
      "const": "manifest-complete-risk-directed"
    },
    "mandatoryComplete": {
      "type": "boolean"
    },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "groupId",
          "totalCount",
          "readCount",
          "unreadCount",
          "unreadObjectSetDigest"
        ],
        "properties": {
          "groupId": {
            "type": "string",
            "enum": [
              "security-auth",
              "protocol-schema",
              "persistence-migration",
              "provider-adapter",
              "console-ui",
              "tests-evaluations",
              "documentation",
              "generated-other"
            ]
          },
          "totalCount": {
            "type": "integer",
            "minimum": 0
          },
          "readCount": {
            "type": "integer",
            "minimum": 0
          },
          "unreadCount": {
            "type": "integer",
            "minimum": 0
          },
          "unreadObjectSetDigest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      },
      "minItems": 0,
      "maxItems": 8,
      "uniqueItems": true
    },
    "byteComplete": {
      "type": "boolean"
    }
  },
  "x-coverageGroupsOrdered": true,
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
