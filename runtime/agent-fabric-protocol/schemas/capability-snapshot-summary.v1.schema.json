{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "admission",
    "dispatch"
  ],
  "properties": {
    "admission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshotRef",
        "source",
        "observedAt",
        "expiresAt"
      ],
      "properties": {
        "snapshotRef": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "snapshotId",
            "snapshotGeneration",
            "snapshotDigest",
            "capabilityBodyDigest"
          ],
          "properties": {
            "snapshotId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "snapshotGeneration": {
              "type": "integer",
              "minimum": 1
            },
            "snapshotDigest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            },
            "capabilityBodyDigest": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            }
          }
        },
        "source": {
          "type": "string",
          "enum": [
            "runtime-discovery",
            "version-pinned-conformance",
            "unavailable"
          ]
        },
        "observedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "dispatch": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "snapshotRef",
            "source",
            "observedAt",
            "expiresAt"
          ],
          "properties": {
            "snapshotRef": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "snapshotId",
                "snapshotGeneration",
                "snapshotDigest",
                "capabilityBodyDigest"
              ],
              "properties": {
                "snapshotId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "x-minUtf8Bytes": 1,
                  "x-maxUtf8Bytes": 256
                },
                "snapshotGeneration": {
                  "type": "integer",
                  "minimum": 1
                },
                "snapshotDigest": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                },
                "capabilityBodyDigest": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                }
              }
            },
            "source": {
              "type": "string",
              "enum": [
                "runtime-discovery",
                "version-pinned-conformance",
                "unavailable"
              ]
            },
            "observedAt": {
              "type": "string",
              "format": "date-time"
            },
            "expiresAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
