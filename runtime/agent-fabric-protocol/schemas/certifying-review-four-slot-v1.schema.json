{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "profileId",
    "profileSchemaDigest",
    "targetChairFamily",
    "slots",
    "resolvedProfileDigest"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "profileId": {
      "const": "certifying-review-four-slot-v1"
    },
    "profileSchemaDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "targetChairFamily": {
      "type": "string",
      "enum": [
        "openai",
        "anthropic"
      ]
    },
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schemaVersion",
          "slot",
          "adapterClass",
          "adapterId",
          "adapterContractDigest",
          "providerFamily",
          "model",
          "requiredActualEndpointProvider",
          "requiredActualProviderFamily",
          "requiredActualModel",
          "requestedEffort",
          "resolvedEffort",
          "sourceMode",
          "runtimeIdentityDigest",
          "platformIdentityDigest",
          "providerTurnCeiling",
          "internalStepCeiling",
          "mandatoryReadOps",
          "mandatoryReadBytes",
          "explorationReadOps",
          "explorationReadBytes",
          "routeAliases",
          "riskReadMapDigest",
          "reviewerFamilyRelation"
        ],
        "properties": {
          "schemaVersion": {
            "const": 1
          },
          "slot": {
            "type": "string",
            "enum": [
              "native",
              "other-primary",
              "cursor-grok",
              "agy-gemini"
            ]
          },
          "adapterClass": {
            "type": "string",
            "enum": [
              "primary-native",
              "equal-primary",
              "cursor",
              "agy"
            ]
          },
          "adapterId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          },
          "adapterContractDigest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "providerFamily": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          },
          "model": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          },
          "requiredActualEndpointProvider": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          },
          "requiredActualProviderFamily": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          },
          "requiredActualModel": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "x-minUtf8Bytes": 1,
            "x-maxUtf8Bytes": 256
          },
          "requestedEffort": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1,
                "maxLength": 256,
                "x-minUtf8Bytes": 1,
                "x-maxUtf8Bytes": 256
              },
              {
                "type": "null"
              }
            ]
          },
          "resolvedEffort": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "kind",
                  "value"
                ],
                "properties": {
                  "kind": {
                    "const": "applied"
                  },
                  "value": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "x-minUtf8Bytes": 1,
                    "x-maxUtf8Bytes": 256
                  }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "kind"
                ],
                "properties": {
                  "kind": {
                    "const": "inapplicable"
                  }
                }
              }
            ]
          },
          "sourceMode": {
            "type": "string",
            "enum": [
              "direct-portal",
              "portal-helper"
            ]
          },
          "runtimeIdentityDigest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "platformIdentityDigest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "providerTurnCeiling": {
            "type": "integer",
            "minimum": 1
          },
          "internalStepCeiling": {
            "type": "integer",
            "minimum": 0
          },
          "mandatoryReadOps": {
            "type": "integer",
            "minimum": 0
          },
          "mandatoryReadBytes": {
            "type": "integer",
            "minimum": 0
          },
          "explorationReadOps": {
            "type": "integer",
            "minimum": 0
          },
          "explorationReadBytes": {
            "type": "integer",
            "minimum": 0
          },
          "routeAliases": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 256
            },
            "minItems": 1,
            "maxItems": 64,
            "uniqueItems": true
          },
          "riskReadMapDigest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "reviewerFamilyRelation": {
            "type": "string",
            "enum": [
              "same-family-exempt",
              "distinct-family-proved"
            ]
          }
        }
      },
      "minItems": 4,
      "maxItems": 4
    },
    "resolvedProfileDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "x-fourSlotProfileMatrix": true,
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
