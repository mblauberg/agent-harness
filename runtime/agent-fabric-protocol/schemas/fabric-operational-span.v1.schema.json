{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "spanId",
    "parentSpanId",
    "runId",
    "taskId",
    "agentId",
    "actionRef",
    "routeAdmissionDigest",
    "operation",
    "status",
    "durationMs",
    "inputTokens",
    "outputTokens",
    "retryCount",
    "errorCode",
    "observedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "spanId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "parentSpanId": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        {
          "type": "null"
        }
      ]
    },
    "runId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "x-minUtf8Bytes": 1,
      "x-maxUtf8Bytes": 256
    },
    "taskId": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        {
          "type": "null"
        }
      ]
    },
    "agentId": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        {
          "type": "null"
        }
      ]
    },
    "actionRef": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "adapterId",
            "actionId"
          ],
          "properties": {
            "adapterId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "actionId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            }
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "routeAdmissionDigest": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "operation": {
      "type": "string",
      "enum": [
        "fabric.v1.authority.delegate",
        "fabric.v1.agent.register",
        "fabric.v1.agent.spawn",
        "fabric.v1.agent.attach",
        "fabric.v1.message.send",
        "fabric.v1.discussion-group.create",
        "fabric.v1.message.receive",
        "fabric.v1.delivery.acknowledge",
        "fabric.v1.delivery.abandon",
        "fabric.v1.mailbox.read",
        "fabric.v1.task.create",
        "fabric.v1.task.claim",
        "fabric.v1.task.readiness.refresh",
        "fabric.v1.task.objective-check.record",
        "fabric.v1.task.handoff.acknowledge",
        "fabric.v1.task.read",
        "fabric.v1.task.update",
        "fabric.v1.task.owner-recovery-proof.record",
        "fabric.v1.task.owner.recover",
        "fabric.v1.lease.revocation-proof.record",
        "fabric.v1.capability.revoke",
        "fabric.v1.capability.rotate",
        "fabric.v1.write-lease.acquire",
        "fabric.v1.write-lease.recover",
        "fabric.v1.write-lease.renew",
        "fabric.v1.write-lease.read",
        "fabric.v1.write-lease.release",
        "fabric.v1.lifecycle.request",
        "fabric.v1.lifecycle.read",
        "fabric.v1.provider-state.report",
        "fabric.v1.provider-action.dispatch",
        "fabric.v1.provider-action.reconcile",
        "fabric.v1.provider-action.read",
        "fabric.v1.operator-intervention.record",
        "fabric.v1.visibility-failure.record",
        "fabric.v1.team.create",
        "fabric.v1.team.read",
        "fabric.v1.subtree.freeze",
        "fabric.v1.subtree.adopt",
        "fabric.v1.subtree-barrier.close",
        "fabric.v1.budget.reserve",
        "fabric.v1.budget.usage.record",
        "fabric.v1.budget.usage.reconcile",
        "fabric.v1.budget.release",
        "fabric.v1.budget.read",
        "fabric.v1.artifact.publish",
        "fabric.v1.barrier.close",
        "fabric.v1.whoami",
        "fabric.v1.run-status.read",
        "fabric.v1.events.observe",
        "fabric.v1.task.list",
        "fabric.v1.agent.list",
        "fabric.v1.receipt.list",
        "fabric.v1.receipt.export",
        "fabric.v1.launch.attest",
        "fabric.v1.project-session.create",
        "fabric.v1.project-session.read",
        "fabric.v1.project-session.transition",
        "fabric.v1.project-session.close",
        "fabric.v1.project-session-launch.packet.prepare",
        "fabric.v1.project-session-launch.prepare",
        "fabric.v1.project-session.membership.bind",
        "fabric.v1.operator.attach",
        "fabric.v1.operator.detach",
        "fabric.v1.operator.heartbeat",
        "fabric.v1.integration.input-attest",
        "fabric.v1.intake.draft.create",
        "fabric.v1.intake.read",
        "fabric.v1.intake.submit",
        "fabric.v1.intake.revise",
        "fabric.v1.scoped-gate.create",
        "fabric.v1.scoped-gate.resolve",
        "fabric.v1.scoped-gate.check",
        "fabric.v1.scoped-gate.read",
        "fabric.v1.resource.reserve",
        "fabric.v1.resource.release",
        "fabric.v1.resource.reconcile",
        "fabric.v1.task.request",
        "fabric.v1.task.complete-with-reply",
        "fabric.v1.result-delivery.claim",
        "fabric.v1.result-delivery.provider-accept",
        "fabric.v1.result-delivery.consume",
        "fabric.v1.result-delivery.retry",
        "fabric.v1.result-delivery.reassign",
        "fabric.v1.result-delivery.abandon",
        "fabric.v1.workstream.create",
        "fabric.v1.workstream.settle",
        "fabric.v1.chair.takeover",
        "fabric.v1.project.discover",
        "fabric.v1.operator-projection.snapshot",
        "fabric.v1.operator-projection.page",
        "fabric.v1.operator-projection.events",
        "fabric.v1.operator-projection.view-page",
        "fabric.v1.operator-projection.detail.read",
        "fabric.v1.operator-action.preview",
        "fabric.v1.operator-action.commit",
        "fabric.v1.operator-action.status",
        "fabric.v1.operator-action.reconcile",
        "fabric.v1.agent-lifecycle-recovery-checkpoint.validate",
        "fabric.v1.message-body.read",
        "fabric.v1.operator-repository.read",
        "fabric.v1.evidence.publish",
        "fabric.v1.operator-artifact-content.read",
        "fabric.v1.review-target.prepare",
        "fabric.v1.review-target-preparation.read",
        "fabric.v1.review-target.rebind",
        "fabric.v1.review-evidence.read",
        "fabric.v1.review-evidence.list",
        "fabric.v1.review-evidence.annotate",
        "fabric.v1.review-evidence-annotation.current.read",
        "fabric.v1.review-finding-page.read",
        "fabric.v1.review-completion.read",
        "fabric.v1.provider-route-integrity-recovery.read",
        "fabric.v1.provider-context-pressure.read",
        "fabric.v1.herdr-steer.dispatch",
        "fabric.v1.topology-wave.append",
        "fabric.v1.topology-wave.current.read",
        "fabric.v1.topology-wave.list"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "error",
        "cancelled",
        "unknown"
      ]
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0
    },
    "inputTokens": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "outputTokens": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "retryCount": {
      "type": "integer",
      "minimum": 0
    },
    "errorCode": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "x-minUtf8Bytes": 1,
          "x-maxUtf8Bytes": 256
        },
        {
          "type": "null"
        }
      ]
    },
    "observedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
