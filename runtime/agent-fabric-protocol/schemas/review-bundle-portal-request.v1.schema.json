{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jsonrpc",
        "id",
        "method",
        "params"
      ],
      "properties": {
        "jsonrpc": {
          "const": "2.0"
        },
        "id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 2147483647
            },
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 64,
              "pattern": "^[A-Za-z0-9._:-]{1,64}$"
            }
          ]
        },
        "method": {
          "const": "tools/call"
        },
        "params": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "arguments"
          ],
          "properties": {
            "name": {
              "const": "review_bundle_read"
            },
            "arguments": {
              "oneOf": [
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "schemaVersion",
                    "bundleDigest",
                    "payloadDigest",
                    "kind",
                    "parentDigest",
                    "ordinal"
                  ],
                  "properties": {
                    "schemaVersion": {
                      "const": 1
                    },
                    "bundleDigest": {
                      "type": "string",
                      "pattern": "^sha256:[a-f0-9]{64}$"
                    },
                    "payloadDigest": {
                      "type": "string",
                      "pattern": "^sha256:[a-f0-9]{64}$"
                    },
                    "kind": {
                      "const": "manifest-root"
                    },
                    "parentDigest": {
                      "const": null
                    },
                    "ordinal": {
                      "const": 0
                    }
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "schemaVersion",
                    "bundleDigest",
                    "payloadDigest",
                    "kind",
                    "parentDigest",
                    "ordinal"
                  ],
                  "properties": {
                    "schemaVersion": {
                      "const": 1
                    },
                    "bundleDigest": {
                      "type": "string",
                      "pattern": "^sha256:[a-f0-9]{64}$"
                    },
                    "payloadDigest": {
                      "type": "string",
                      "pattern": "^sha256:[a-f0-9]{64}$"
                    },
                    "kind": {
                      "type": "string",
                      "enum": [
                        "manifest-body-page",
                        "object",
                        "chunk"
                      ]
                    },
                    "parentDigest": {
                      "type": "string",
                      "pattern": "^sha256:[a-f0-9]{64}$"
                    },
                    "ordinal": {
                      "type": "integer",
                      "minimum": 0
                    }
                  }
                }
              ]
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jsonrpc",
        "id",
        "method",
        "params"
      ],
      "properties": {
        "jsonrpc": {
          "const": "2.0"
        },
        "id": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 2147483647
            },
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "x-minUtf8Bytes": 1,
              "x-maxUtf8Bytes": 64,
              "pattern": "^[A-Za-z0-9._:-]{1,64}$"
            }
          ]
        },
        "method": {
          "const": "tools/call"
        },
        "params": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "arguments"
          ],
          "properties": {
            "name": {
              "const": "review_bundle_search"
            },
            "arguments": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "schemaVersion",
                "bundleDigest",
                "queryKind",
                "query",
                "maximumResults"
              ],
              "properties": {
                "schemaVersion": {
                  "const": 1
                },
                "bundleDigest": {
                  "type": "string",
                  "pattern": "^sha256:[a-f0-9]{64}$"
                },
                "queryKind": {
                  "type": "string",
                  "enum": [
                    "literal",
                    "token"
                  ]
                },
                "query": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "x-minUtf8Bytes": 1,
                  "x-maxUtf8Bytes": 256
                },
                "maximumResults": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 100
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "boundedJsonValue": {
      "x-boundedJson": true,
      "$ref": "#/$defs/jsonValueNode"
    },
    "jsonValueNode": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string",
          "maxLength": 1048576,
          "x-maxUtf8Bytes": 1048576
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/jsonValueNode"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "propertyNames": {
            "maxLength": 256,
            "x-maxUtf8Bytes": 256
          },
          "additionalProperties": {
            "$ref": "#/$defs/jsonValueNode"
          }
        }
      ]
    }
  }
}
