{
  "name": "@local/agent-fabric-herdr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "bin": {
    "agent-fabric-herdr": "dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "precheck": "npm run build --include-workspace-root",
    "check": "npm run typecheck && npm run build && npm run test"
  },
  "dependencies": {
    "@local/agent-fabric-protocol": "file:../agent-fabric-protocol"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
