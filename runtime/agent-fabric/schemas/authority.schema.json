{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/agent-fabric/v1/authority.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["workspaceRoots", "sourcePaths", "artifactPaths", "actions", "disclosure", "expiresAt", "budget"],
  "properties": {
    "workspaceRoots": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true, "minItems": 1},
    "sourcePaths": {"$ref": "#/$defs/paths"},
    "artifactPaths": {"$ref": "#/$defs/paths"},
    "actions": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/action"}
    },
    "deniedPaths": {"$ref": "#/$defs/paths"},
    "deniedActions": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/action"}
    },
    "disclosure": {
      "oneOf": [
        {"type": "object", "properties": {"level": {"const": "allowed"}}, "required": ["level"], "additionalProperties": false},
        {"type": "object", "properties": {"level": {"const": "forbidden"}}, "required": ["level"], "additionalProperties": false},
        {
          "type": "object",
          "properties": {
            "level": {"const": "scoped"},
            "scopes": {"type": "array", "items": {"enum": ["local", "approved-provider", "external"]}, "minItems": 1, "maxItems": 2, "uniqueItems": true}
          },
          "required": ["level", "scopes"],
          "additionalProperties": false
        }
      ]
    },
    "expiresAt": {"type": "string", "minLength": 1},
    "budget": {
      "type": "object",
      "propertyNames": {"$ref": "#/$defs/budgetUnit"},
      "additionalProperties": {"type": "integer", "minimum": 0}
    }
  },
  "$defs": {
    "paths": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "action": {"enum": ["fabric.v1.authority.delegate","fabric.v1.agent.register","fabric.v1.agent.spawn","fabric.v1.agent.attach","fabric.v1.message.send","fabric.v1.discussion-group.create","fabric.v1.message.receive","fabric.v1.delivery.acknowledge","fabric.v1.delivery.abandon","fabric.v1.mailbox.read","fabric.v1.task.create","fabric.v1.task.claim","fabric.v1.task.readiness.refresh","fabric.v1.task.objective-check.record","fabric.v1.task.handoff.acknowledge","fabric.v1.task.read","fabric.v1.task.update","fabric.v1.task.owner-recovery-proof.record","fabric.v1.task.owner.recover","fabric.v1.lease.revocation-proof.record","fabric.v1.capability.revoke","fabric.v1.capability.rotate","fabric.v1.write-lease.acquire","fabric.v1.write-lease.recover","fabric.v1.write-lease.renew","fabric.v1.write-lease.read","fabric.v1.write-lease.release","fabric.v1.lifecycle.request","fabric.v1.lifecycle.read","fabric.v1.provider-state.report","fabric.v1.provider-action.dispatch","fabric.v1.provider-action.reconcile","fabric.v1.provider-action.read","fabric.v1.operator-intervention.record","fabric.v1.visibility-failure.record","fabric.v1.team.create","fabric.v1.team.read","fabric.v1.subtree.freeze","fabric.v1.subtree.adopt","fabric.v1.subtree-barrier.close","fabric.v1.budget.reserve","fabric.v1.budget.usage.record","fabric.v1.budget.usage.reconcile","fabric.v1.budget.release","fabric.v1.budget.read","fabric.v1.artifact.publish","fabric.v1.evidence.publish","fabric.v1.barrier.close","fabric.v1.run-status.read","fabric.v1.events.observe","fabric.v1.task.list","fabric.v1.agent.list","fabric.v1.receipt.list","fabric.v1.receipt.export","fabric.v1.project-session.membership.bind","fabric.v1.intake.revise","fabric.v1.scoped-gate.create","fabric.v1.scoped-gate.check","fabric.v1.resource.reserve","fabric.v1.resource.release","fabric.v1.resource.reconcile","fabric.v1.task.request","fabric.v1.task.complete-with-reply","fabric.v1.result-delivery.claim","fabric.v1.result-delivery.consume","fabric.v1.result-delivery.retry","fabric.v1.result-delivery.reassign","fabric.v1.result-delivery.abandon","fabric.v1.workstream.create","fabric.v1.workstream.settle"]},
    "budgetUnit": {
      "anyOf": [
        {"enum": ["turns","provider_calls","concurrent_turns","descendants","message_bytes","artifact_bytes","wall_clock_milliseconds"]},
        {"enum": ["cost:AED","cost:AFN","cost:ALL","cost:AMD","cost:ANG","cost:AOA","cost:ARS","cost:AUD","cost:AWG","cost:AZN","cost:BAM","cost:BBD","cost:BDT","cost:BGN","cost:BHD","cost:BIF","cost:BMD","cost:BND","cost:BOB","cost:BRL","cost:BSD","cost:BTN","cost:BWP","cost:BYN","cost:BZD","cost:CAD","cost:CDF","cost:CHF","cost:CLP","cost:CNY","cost:COP","cost:CRC","cost:CUC","cost:CUP","cost:CVE","cost:CZK","cost:DJF","cost:DKK","cost:DOP","cost:DZD","cost:EGP","cost:ERN","cost:ETB","cost:EUR","cost:FJD","cost:FKP","cost:GBP","cost:GEL","cost:GHS","cost:GIP","cost:GMD","cost:GNF","cost:GTQ","cost:GYD","cost:HKD","cost:HNL","cost:HRK","cost:HTG","cost:HUF","cost:IDR","cost:ILS","cost:INR","cost:IQD","cost:IRR","cost:ISK","cost:JMD","cost:JOD","cost:JPY","cost:KES","cost:KGS","cost:KHR","cost:KMF","cost:KPW","cost:KRW","cost:KWD","cost:KYD","cost:KZT","cost:LAK","cost:LBP","cost:LKR","cost:LRD","cost:LSL","cost:LYD","cost:MAD","cost:MDL","cost:MGA","cost:MKD","cost:MMK","cost:MNT","cost:MOP","cost:MRU","cost:MUR","cost:MVR","cost:MWK","cost:MXN","cost:MYR","cost:MZN","cost:NAD","cost:NGN","cost:NIO","cost:NOK","cost:NPR","cost:NZD","cost:OMR","cost:PAB","cost:PEN","cost:PGK","cost:PHP","cost:PKR","cost:PLN","cost:PYG","cost:QAR","cost:RON","cost:RSD","cost:RUB","cost:RWF","cost:SAR","cost:SBD","cost:SCR","cost:SDG","cost:SEK","cost:SGD","cost:SHP","cost:SLE","cost:SLL","cost:SOS","cost:SRD","cost:SSP","cost:STN","cost:SVC","cost:SYP","cost:SZL","cost:THB","cost:TJS","cost:TMT","cost:TND","cost:TOP","cost:TRY","cost:TTD","cost:TWD","cost:TZS","cost:UAH","cost:UGX","cost:USD","cost:UYU","cost:UZS","cost:VES","cost:VND","cost:VUV","cost:WST","cost:XAF","cost:XCD","cost:XCG","cost:XDR","cost:XOF","cost:XPF","cost:XSU","cost:YER","cost:ZAR","cost:ZMW","cost:ZWG","cost:ZWL"]},
        {"type": "string", "pattern": "^(?:input_tokens|output_tokens):[a-z0-9]+(?:[.-][a-z0-9]+)*$"}
      ]
    }
  }
}
