{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-fabric.local/schemas/review-diff.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "objectFormat",
    "baseObjectId",
    "headObjectId",
    "codecDigest",
    "rulesDigest",
    "entries",
    "reviewDiffSetDigest"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "objectFormat": {
      "enum": [
        "sha1",
        "sha256"
      ]
    },
    "baseObjectId": {
      "type": "string",
      "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"
    },
    "headObjectId": {
      "type": "string",
      "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"
    },
    "codecDigest": {
      "$ref": "#/$defs/digest"
    },
    "rulesDigest": {
      "$ref": "#/$defs/digest"
    },
    "entries": {
      "type": "array",
      "maxItems": 4096,
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    "reviewDiffSetDigest": {
      "$ref": "#/$defs/digest"
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "mode": {
      "enum": [
        "100644",
        "100755",
        "120000",
        "160000",
        null
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "objectDigest",
        "byteLength"
      ],
      "properties": {
        "mode": {
          "enum": [
            "100644",
            "100755",
            "120000",
            "160000"
          ]
        },
        "objectDigest": {
          "$ref": "#/$defs/digest"
        },
        "byteLength": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "oldStart",
        "oldCount",
        "newStart",
        "newCount",
        "segmentDigest"
      ],
      "properties": {
        "kind": {
          "enum": [
            "equal",
            "delete",
            "insert"
          ]
        },
        "oldStart": {
          "type": "integer",
          "minimum": 0
        },
        "oldCount": {
          "type": "integer",
          "minimum": 0
        },
        "newStart": {
          "type": "integer",
          "minimum": 0
        },
        "newCount": {
          "type": "integer",
          "minimum": 0
        },
        "segmentDigest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "payload": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "operations"
          ],
          "properties": {
            "kind": {
              "const": "text-edits"
            },
            "operations": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/operation"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "beforeDigest",
            "afterDigest",
            "beforeBytes",
            "afterBytes"
          ],
          "properties": {
            "kind": {
              "const": "binary-summary"
            },
            "beforeDigest": {
              "oneOf": [
                {
                  "$ref": "#/$defs/digest"
                },
                {
                  "type": "null"
                }
              ]
            },
            "afterDigest": {
              "oneOf": [
                {
                  "$ref": "#/$defs/digest"
                },
                {
                  "type": "null"
                }
              ]
            },
            "beforeBytes": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            },
            "afterBytes": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            }
          }
        }
      ]
    },
    "diffObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "status",
        "path",
        "oldPath",
        "before",
        "after",
        "payload"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "status": {
          "enum": [
            "added",
            "modified",
            "deleted",
            "renamed",
            "mode-changed"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "oldPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "before": {
          "oneOf": [
            {
              "$ref": "#/$defs/summary"
            },
            {
              "type": "null"
            }
          ]
        },
        "after": {
          "oneOf": [
            {
              "$ref": "#/$defs/summary"
            },
            {
              "type": "null"
            }
          ]
        },
        "payload": {
          "$ref": "#/$defs/payload"
        }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ordinal",
        "path",
        "status",
        "oldPath",
        "beforeMode",
        "afterMode",
        "beforeObjectDigest",
        "afterObjectDigest",
        "diffObjectDigest",
        "diffObject"
      ],
      "properties": {
        "ordinal": {
          "type": "integer",
          "minimum": 0
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "added",
            "modified",
            "deleted",
            "renamed",
            "mode-changed"
          ]
        },
        "oldPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "beforeMode": {
          "$ref": "#/$defs/mode"
        },
        "afterMode": {
          "$ref": "#/$defs/mode"
        },
        "beforeObjectDigest": {
          "oneOf": [
            {
              "$ref": "#/$defs/digest"
            },
            {
              "type": "null"
            }
          ]
        },
        "afterObjectDigest": {
          "oneOf": [
            {
              "$ref": "#/$defs/digest"
            },
            {
              "type": "null"
            }
          ]
        },
        "diffObjectDigest": {
          "$ref": "#/$defs/digest"
        },
        "diffObject": {
          "$ref": "#/$defs/diffObject"
        }
      }
    }
  }
}
