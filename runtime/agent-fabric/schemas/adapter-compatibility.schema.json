{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/agent-fabric/v1/adapter-compatibility.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "verification_date", "adapter_contract_version", "capability_fixture_version", "activation_policy", "adapters"],
  "properties": {
    "schema_version": {"const": 1},
    "verification_date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "adapter_contract_version": {"const": 1},
    "capability_fixture_version": {"const": 1},
    "activation_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["real_adapters_require_separate_gate", "default_enabled"],
      "properties": {
        "real_adapters_require_separate_gate": {"const": true},
        "default_enabled": {"const": false}
      }
    },
    "adapters": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"$ref": "#/$defs/adapter"}
    }
  },
  "$defs": {
    "nullableString": {"anyOf": [{"type": "string"}, {"type": "null"}]},
    "nullableSha256": {"anyOf": [{"type": "string", "pattern": "^[0-9a-f]{64}$"}, {"type": "null"}]},
    "stringArray": {"type": "array", "items": {"type": "string"}},
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "installed_version"],
      "properties": {
        "kind": {"type": "string"},
        "package": {"type": "string"},
        "command": {"type": "string"},
        "installed_version": {"type": "string"},
        "source_build": {"$ref": "#/$defs/nullableString"},
        "resolved_artifact": {"type": "string"},
        "lock_integrity_sha512": {"type": "string", "pattern": "^[A-Za-z0-9+/]{86}==$"},
        "entrypoint": {"type": "string"},
        "entrypoint_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "wrapper_entrypoint": {"type": "string", "minLength": 1},
        "wrapper_entrypoint_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "wrapper_manifest": {"type": "string", "minLength": 1},
        "wrapper_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "executable": {"type": "string"},
        "executable_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "rpc_entrypoint": {"type": "string"},
        "rpc_entrypoint_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "bundle_entrypoint": {"type": "string"},
        "bundle_entrypoint_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "package_manifest": {"type": "string"},
        "package_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter_version", "protocol", "protocol_version", "capability_fixture_version"],
      "properties": {
        "adapter_version": {"const": 1},
        "protocol": {"type": "string"},
        "protocol_version": {"anyOf": [{"type": "string"}, {"type": "integer"}, {"type": "null"}]},
        "schema_version": {"type": "integer"},
        "schema_generator": {"type": "string"},
        "schema_source": {"$ref": "#/$defs/nullableString"},
        "schema_bundle": {"type": "string"},
        "schema_sha256": {"$ref": "#/$defs/nullableSha256"},
        "capability_fixture_version": {"const": 1},
        "agent_engine": {"type": "string"}
      }
    },
    "runtimeRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platforms"],
      "properties": {
        "fabric_node": {"type": "string"},
        "upstream_node": {"type": "string"},
        "supported_cli_versions": {"$ref": "#/$defs/stringArray"},
        "supported_protocol_versions": {"type": "array", "items": {"type": "integer"}},
        "minimum_macos": {"type": "string"},
        "platforms": {"$ref": "#/$defs/stringArray"}
      }
    },
    "modelConstraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed"],
      "properties": {
        "allowed": {"$ref": "#/$defs/stringArray"},
        "allowed_model_patterns": {"$ref": "#/$defs/stringArray"},
        "requires_explicit_model": {"type": "boolean"},
        "route_role": {"type": "string"}
      }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "delivery_stage", "implementation", "contract", "runtime_range", "model_family_constraints", "official_source_url", "unresolved_pins"],
      "properties": {
        "enabled": {"type": "boolean"},
        "delivery_stage": {"type": "integer", "minimum": 3, "maximum": 4},
        "implementation": {"$ref": "#/$defs/implementation"},
        "contract": {"$ref": "#/$defs/contract"},
        "runtime_range": {"$ref": "#/$defs/runtimeRange"},
        "model_family_constraints": {"$ref": "#/$defs/modelConstraints"},
        "official_source_url": {"type": "string", "minLength": 1},
        "unresolved_pins": {"$ref": "#/$defs/stringArray"}
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": {"const": true},
              "unresolved_pins": {"type": "array", "maxItems": 0}
            },
            "required": ["enabled", "unresolved_pins"]
          },
          "then": {
            "properties": {
              "implementation": {
                "type": "object",
                "properties": {
                  "wrapper_entrypoint": {"type": "string", "minLength": 1},
                  "wrapper_entrypoint_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
                  "wrapper_manifest": {"type": "string", "minLength": 1},
                  "wrapper_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
                },
                "required": ["wrapper_entrypoint", "wrapper_entrypoint_sha256", "wrapper_manifest", "wrapper_manifest_sha256"]
              },
              "contract": {
                "type": "object",
                "properties": {
                  "protocol_version": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "integer"}]},
                  "schema_source": {"type": "string", "minLength": 1},
                  "schema_bundle": {"type": "string", "minLength": 1},
                  "schema_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
                },
                "required": ["protocol_version", "schema_sha256"],
                "anyOf": [
                  {"properties": {"schema_source": {"type": "string", "minLength": 1}}, "required": ["schema_source"]},
                  {"properties": {"schema_bundle": {"type": "string", "minLength": 1}}, "required": ["schema_bundle"]}
                ]
              }
            }
          }
        }
      ]
    }
  }
}
