{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/agent-fabric/v1/config.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion"],
  "properties": {
    "schemaVersion": {"const": 1},
    "allowedAdapters": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "activeAdapters": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "allowedProfiles": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "adapters": {"$ref": "#/$defs/adapters"},
    "workspaceRoots": {"$ref": "#/$defs/workspaceRoots"},
    "limits": {"$ref": "#/$defs/limits"},
    "environmentSources": {"type": "array", "items": {"type": "string"}},
    "listener": {"type": "string"},
    "providerCredentialSelector": {"type": "string"}
  },
  "$defs": {
    "adapters": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command"],
        "properties": {
          "command": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
        }
      }
    },
    "workspaceRoots": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maximumConcurrentProviderTurns"],
      "properties": {
        "maximumConcurrentProviderTurns": {"type": "integer", "minimum": 1, "maximum": 8}
      }
    },
    "projectLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maximumConcurrentProviderTurns"],
      "properties": {
        "maximumConcurrentProviderTurns": {"type": "integer", "minimum": 1}
      }
    },
    "projectConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion"],
      "properties": {
        "schemaVersion": {"const": 1},
        "namedExecutionProfile": {"type": "string"},
        "allowListedAdapterId": {"type": "string"},
        "workspaceRoots": {"$ref": "#/$defs/workspaceRoots"},
        "limits": {"$ref": "#/$defs/projectLimits"}
      }
    }
  }
}
