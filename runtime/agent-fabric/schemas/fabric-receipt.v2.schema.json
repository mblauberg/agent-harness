{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/agent-fabric/v2/fabric-receipt.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "runId", "chair", "taskOwners", "agents",
    "executionProfile", "directInputProvenance", "modelRoutingReceipts",
    "taskAndWriteLeases", "messageAndDeliveryCounts", "objectiveChecks",
    "crossFamilyReviews", "providerFailuresAndSubstitutions", "operatorInterventions",
    "compactionsAndRotations", "eventWatermark", "counts", "stateHash"
  ],
  "properties": {
    "schemaVersion": {"const": 2},
    "runId": {"type": "string", "minLength": 1},
    "chair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agentId", "adapterId"],
      "properties": {
        "agentId": {"type": "string", "minLength": 1},
        "adapterId": {"type": ["string", "null"]}
      }
    },
    "taskOwners": {
      "type": "array",
      "items": {"$ref": "https://agent-harness.local/agent-fabric/v1/fabric-receipt.schema.json#/$defs/stageOwner"}
    },
    "agents": {
      "type": "array",
      "items": {"$ref": "https://agent-harness.local/agent-fabric/v1/fabric-receipt.schema.json#/$defs/agent"}
    },
    "executionProfile": {"type": "string", "minLength": 1},
    "directInputProvenance": {"enum": ["complete", "partial", "unavailable"]},
    "modelRoutingReceipts": {
      "type": "array",
      "items": {"$ref": "https://agent-harness.local/agent-fabric/v1/fabric-receipt.schema.json#/$defs/modelRoutingReceipt"}
    },
    "taskAndWriteLeases": {
      "type": "array",
      "items": {"$ref": "https://agent-harness.local/agent-fabric/v1/fabric-receipt.schema.json#/$defs/taskOrWriteLease"}
    },
    "messageAndDeliveryCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["messages", "deliveries"],
      "properties": {
        "messages": {"type": "integer", "minimum": 0},
        "deliveries": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ready", "claimed", "acknowledged", "abandoned", "expired"],
          "properties": {
            "ready": {"type": "integer", "minimum": 0},
            "claimed": {"type": "integer", "minimum": 0},
            "acknowledged": {"type": "integer", "minimum": 0},
            "abandoned": {"type": "integer", "minimum": 0},
            "expired": {"type": "integer", "minimum": 0}
          }
        }
      }
    },
    "objectiveChecks": {
      "type": "array",
      "items": {"$ref": "https://agent-harness.local/agent-fabric/v1/fabric-receipt.schema.json#/$defs/objectiveCheck"}
    },
    "crossFamilyReviews": {
      "type": "array",
      "items": {"$ref": "https://agent-harness.local/agent-fabric/v1/fabric-receipt.schema.json#/$defs/crossFamilyReview"}
    },
    "providerFailuresAndSubstitutions": {
      "type": "array",
      "items": {"$ref": "https://agent-harness.local/agent-fabric/v1/fabric-receipt.schema.json#/$defs/providerFailure"}
    },
    "operatorInterventions": {
      "type": "array",
      "items": {"$ref": "https://agent-harness.local/agent-fabric/v1/fabric-receipt.schema.json#/$defs/operatorIntervention"}
    },
    "compactionsAndRotations": {
      "type": "array",
      "items": {"$ref": "https://agent-harness.local/agent-fabric/v1/fabric-receipt.schema.json#/$defs/lifecycleOperation"}
    },
    "eventWatermark": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["eventId", "createdAt"],
          "properties": {
            "eventId": {"type": "string", "minLength": 1},
            "createdAt": {"type": "string", "format": "date-time"}
          }
        }
      ]
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agents", "tasks", "messages", "leases", "events"],
      "properties": {
        "agents": {"type": "integer", "minimum": 0},
        "tasks": {"type": "integer", "minimum": 0},
        "messages": {"type": "integer", "minimum": 0},
        "leases": {"type": "integer", "minimum": 0},
        "events": {"type": "integer", "minimum": 0}
      }
    },
    "stateHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
