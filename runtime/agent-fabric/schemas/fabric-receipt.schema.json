{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/agent-fabric/v1/fabric-receipt.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "runId", "chair", "observedAt", "stageOwners", "agents",
    "executionProfile", "directInputProvenance", "modelRoutingReceipts",
    "taskAndWriteLeases", "messagesSentReceivedAbandoned", "objectiveChecks",
    "crossFamilyReviews", "providerFailuresAndSubstitutions", "operatorInterventions",
    "compactionsAndRotations", "counts"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "runId": {"type": "string", "minLength": 1},
    "chair": {
      "type": "object", "additionalProperties": false, "required": ["agentId", "adapterId"],
      "properties": {"agentId": {"type": "string", "minLength": 1}, "adapterId": {"type": ["string", "null"]}}
    },
    "observedAt": {"type": "string", "format": "date-time"},
    "stageOwners": {"type": "array", "items": {"$ref": "#/$defs/stageOwner"}},
    "agents": {"type": "array", "items": {"$ref": "#/$defs/agent"}},
    "executionProfile": {"type": "string", "minLength": 1},
    "directInputProvenance": {"enum": ["complete", "partial", "unavailable"]},
    "modelRoutingReceipts": {"type": "array", "items": {"$ref": "#/$defs/modelRoutingReceipt"}},
    "taskAndWriteLeases": {"type": "array", "items": {"$ref": "#/$defs/taskOrWriteLease"}},
    "messagesSentReceivedAbandoned": {
      "type": "object", "additionalProperties": false,
      "required": ["sent", "delivered", "acknowledged", "abandoned", "expired"],
      "properties": {
        "sent": {"type": "integer", "minimum": 0}, "delivered": {"type": "integer", "minimum": 0},
        "acknowledged": {"type": "integer", "minimum": 0}, "abandoned": {"type": "integer", "minimum": 0},
        "expired": {"type": "integer", "minimum": 0}
      }
    },
    "objectiveChecks": {"type": "array", "items": {"$ref": "#/$defs/objectiveCheck"}},
    "crossFamilyReviews": {"type": "array", "items": {"$ref": "#/$defs/crossFamilyReview"}},
    "providerFailuresAndSubstitutions": {"type": "array", "items": {"$ref": "#/$defs/providerFailure"}},
    "operatorInterventions": {"type": "array", "items": {"$ref": "#/$defs/operatorIntervention"}},
    "compactionsAndRotations": {"type": "array", "items": {"$ref": "#/$defs/lifecycleOperation"}},
    "counts": {
      "type": "object", "additionalProperties": false,
      "required": ["agents", "tasks", "messages", "deliveries", "leases", "events"],
      "properties": {
        "agents": {"type": "integer", "minimum": 0}, "tasks": {"type": "integer", "minimum": 0},
        "messages": {"type": "integer", "minimum": 0}, "deliveries": {"type": "integer", "minimum": 0},
        "leases": {"type": "integer", "minimum": 0}, "events": {"type": "integer", "minimum": 0}
      }
    }
  },
  "$defs": {
    "modelRoutingReceipt": {
      "type": "object", "additionalProperties": false,
      "required": ["evidenceId", "actionId", "relativePath", "sha256", "receipt", "observedAt"],
      "properties": {
        "evidenceId": {"type": "string", "minLength": 1},
        "actionId": {"type": "string", "minLength": 1},
        "relativePath": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "receipt": {"$ref": "#/$defs/modelRouteReceipt"},
        "observedAt": {"type": "string", "format": "date-time"}
      }
    },
    "crossFamilyReview": {
      "type": "object", "additionalProperties": false,
      "required": ["evidenceId", "reviewerAgentId", "providerFamily", "status", "independent", "relativePath", "sha256", "observedAt"],
      "properties": {
        "evidenceId": {"type": "string", "minLength": 1},
        "reviewerAgentId": {"type": "string", "minLength": 1},
        "providerFamily": {"type": "string", "minLength": 1},
        "status": {"type": "string", "minLength": 1},
        "independent": {"type": "boolean"},
        "relativePath": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "observedAt": {"type": "string", "format": "date-time"}
      }
    },
    "stageOwner": {
      "type": "object", "additionalProperties": false,
      "required": ["taskId", "ownerAgentId", "state", "revision", "ownerLeaseGeneration"],
      "properties": {
        "taskId": {"type": "string"}, "ownerAgentId": {"type": "string"}, "state": {"type": "string"},
        "revision": {"type": "integer"}, "ownerLeaseGeneration": {"type": "integer"}
      }
    },
    "agent": {
      "type": "object", "additionalProperties": false,
      "required": ["agentId", "parentAgentId", "adapterId", "lifecycle", "providerSessionGeneration", "providerSessionReferenceSha256"],
      "properties": {
        "agentId": {"type": "string"}, "parentAgentId": {"type": ["string", "null"]}, "adapterId": {"type": ["string", "null"]},
        "lifecycle": {"type": "string"}, "providerSessionGeneration": {"type": "integer", "minimum": 1},
        "providerSessionReferenceSha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "taskOrWriteLease": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["kind","taskId","holderAgentId","state","revision","generation"], "properties": {"kind":{"const":"task"},"taskId":{"type":"string"},"holderAgentId":{"type":"string"},"state":{"type":"string"},"revision":{"type":"integer"},"generation":{"type":"integer"}}},
        {"type": "object", "additionalProperties": false, "required": ["kind","leaseId","holderAgentId","generation","status","expiresAt","scope"], "properties": {"kind":{"const":"write"},"leaseId":{"type":"string"},"holderAgentId":{"type":"string"},"generation":{"type":"integer"},"status":{"type":"string"},"expiresAt":{"type":"string","format":"date-time"},"scope":{"type":"array","items":{"type":"string"},"uniqueItems":true}}}
      ]
    },
    "objectiveCheck": {"type":"object","additionalProperties":false,"required":["taskId","checkId","status","evidence"],"properties":{"taskId":{"type":"string"},"checkId":{"type":"string"},"status":{"type":"string"},"evidence":{"type":["string","null"]}}},
    "providerFailure": {"type":"object","additionalProperties":false,"required":["actionId","adapterId","operation","status","executionCount","effectCount","observedAt"],"properties":{"actionId":{"type":"string"},"adapterId":{"type":"string"},"operation":{"type":"string"},"status":{"type":"string"},"executionCount":{"type":"integer","minimum":0},"effectCount":{"type":"integer","minimum":0},"observedAt":{"type":"string","format":"date-time"}}},
    "operatorIntervention": {"type":"object","additionalProperties":false,"required":["source","directInputProvenance","taskRevision","summary","observedAt"],"properties":{"source":{"type":"string"},"directInputProvenance":{"enum":["complete","partial","unavailable"]},"taskRevision":{"type":"integer"},"summary":{"type":"string"},"observedAt":{"type":"string","format":"date-time"}}},
    "lifecycleOperation": {"type":"object","additionalProperties":false,"required":["agentId","action","taskId","taskRevision","checkpointSha256","priorResumeReferenceSha256","replacementResumeReferenceSha256","observedAt"],"properties":{"agentId":{"type":"string"},"action":{"type":"string"},"taskId":{"type":"string"},"taskRevision":{"type":"integer"},"checkpointSha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"priorResumeReferenceSha256":{"type":["string","null"],"pattern":"^[0-9a-f]{64}$"},"replacementResumeReferenceSha256":{"type":["string","null"],"pattern":"^[0-9a-f]{64}$"},"observedAt":{"type":"string","format":"date-time"}}},
    "modelRouteReceipt": {
      "type":"object","additionalProperties":false,"required":["schema_version","status","adapter","role"],
      "properties": {
        "schema_version":{"const":1},"status":{"type":"string"},"catalog_date":{"type":"string"},"adapter":{"type":"string"},"alias":{"type":"string"},"role":{"type":"string"},"requested_effort":{"type":"string"},"effort":{"type":"string"},"effort_source":{"type":"string"},"effort_substitution":{"type":"string"},"effort_capability_source":{"type":"string"},"lead_family":{"type":["string","null"]},"adapter_gate":{"type":"string"},"endpoint_provider":{"type":"string"},"model_family":{"type":"string"},"model":{"type":"string"},"resolved_model":{"type":"string"},"identity_source":{"type":"string"},"substitution":{"type":"string"},"fallback_model":{"type":"string"},"distinct_from_lead":{"type":"boolean"},"compatibility_adapter":{"type":"string"},"compatibility_model_family":{"type":"string"},"adapter_enabled":{"type":"boolean"},"adapter_unresolved_pins":{"type":"array","items":{"type":"string"}},"candidates":{"type":"array","items":{"type":"string"}}
      }
    }
  }
}
