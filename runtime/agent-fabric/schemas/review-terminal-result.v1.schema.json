{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-fabric.local/schemas/review-terminal-result.v1.schema.json",
  "oneOf": [
    {
      "$ref": "#/$defs/safe"
    },
    {
      "$ref": "#/$defs/unusable"
    },
    {
      "$ref": "#/$defs/failure"
    },
    {
      "$ref": "#/$defs/noEffect"
    },
    {
      "$ref": "#/$defs/integrity"
    },
    {
      "$ref": "#/$defs/retired"
    }
  ],
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapterId",
        "actionId"
      ],
      "properties": {
        "adapterId": {
          "type": "string",
          "minLength": 1
        },
        "actionId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "common": {
      "schemaVersion": {
        "const": 1
      },
      "actionRef": {
        "$ref": "#/$defs/action"
      },
      "terminalSequence": {
        "type": "integer",
        "minimum": 1
      }
    },
    "safe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "actionRef",
        "terminalSequence",
        "terminalKind",
        "providerAnswerDigest",
        "reviewResultDigest",
        "answerSafety",
        "readCoverageDigest",
        "coverageSummaryDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "actionRef": {
          "$ref": "#/$defs/action"
        },
        "terminalSequence": {
          "type": "integer",
          "minimum": 1
        },
        "terminalKind": {
          "const": "safe-answer"
        },
        "providerAnswerDigest": {
          "$ref": "#/$defs/digest"
        },
        "reviewResultDigest": {
          "$ref": "#/$defs/digest"
        },
        "answerSafety": {
          "const": "safe"
        },
        "readCoverageDigest": {
          "$ref": "#/$defs/digest"
        },
        "coverageSummaryDigest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "unusable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "actionRef",
        "terminalSequence",
        "terminalKind",
        "providerAnswerDigest",
        "reviewResultDigest",
        "answerSafety",
        "readCoverageDigest",
        "coverageSummaryDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "actionRef": {
          "$ref": "#/$defs/action"
        },
        "terminalSequence": {
          "type": "integer",
          "minimum": 1
        },
        "terminalKind": {
          "const": "unusable-answer"
        },
        "providerAnswerDigest": {
          "$ref": "#/$defs/digest"
        },
        "reviewResultDigest": {
          "type": "null"
        },
        "answerSafety": {
          "const": "unusable"
        },
        "readCoverageDigest": {
          "$ref": "#/$defs/digest"
        },
        "coverageSummaryDigest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "actionRef",
        "terminalSequence",
        "terminalKind",
        "providerFailureCode",
        "providerFailureDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "actionRef": {
          "$ref": "#/$defs/action"
        },
        "terminalSequence": {
          "type": "integer",
          "minimum": 1
        },
        "terminalKind": {
          "const": "provider-terminal-failure"
        },
        "providerFailureCode": {
          "enum": [
            "max-turns-exhausted",
            "provider-rejected",
            "terminal-no-answer",
            "adapter-terminal-failure"
          ]
        },
        "providerFailureDigest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "noEffect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "actionRef", "terminalSequence", "terminalKind", "noEffectEvidenceDigest"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "actionRef": { "$ref": "#/$defs/action" },
        "terminalSequence": { "type": "integer", "minimum": 1 },
        "terminalKind": {
          "const": "terminal-no-effect"
        },
        "noEffectEvidenceDigest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "actionRef", "terminalSequence", "terminalKind", "integrityEvidenceDigest"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "actionRef": { "$ref": "#/$defs/action" },
        "terminalSequence": { "type": "integer", "minimum": 1 },
        "terminalKind": {
          "const": "integrity-terminal"
        },
        "integrityEvidenceDigest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "retired": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "actionRef", "terminalSequence", "terminalKind", "retirementEvidenceDigest"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "actionRef": { "$ref": "#/$defs/action" },
        "terminalSequence": { "type": "integer", "minimum": 1 },
        "terminalKind": {
          "const": "retired-unknown"
        },
        "retirementEvidenceDigest": {
          "$ref": "#/$defs/digest"
        }
      }
    }
  }
}
