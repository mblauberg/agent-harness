{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-fabric.local/schemas/review-finding.v1.schema.json",
  "oneOf": [
    {
      "$ref": "#/$defs/finding"
    },
    {
      "$ref": "#/$defs/page"
    },
    {
      "$ref": "#/$defs/set"
    }
  ],
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "currencyRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidenceRef",
        "evidenceRevision",
        "contentDigest"
      ],
      "properties": {
        "evidenceRef": {
          "type": "string",
          "minLength": 1
        },
        "evidenceRevision": {
          "type": "integer",
          "minimum": 1
        },
        "contentDigest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "repair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "originRepositorySourceStateDigest",
        "evidenceRefs"
      ],
      "properties": {
        "kind": {
          "enum": [
            "repository-source",
            "registered-evidence",
            "mixed"
          ]
        },
        "originRepositorySourceStateDigest": {
          "oneOf": [
            {
              "$ref": "#/$defs/digest"
            },
            {
              "type": "null"
            }
          ]
        },
        "evidenceRefs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/currencyRef"
          }
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "findingId",
        "severity",
        "summary",
        "evidence",
        "originTargetGeneration",
        "originActionRef",
        "originResultDigest",
        "originDeliveryManifest",
        "originDeliveryReviewBasisDigest",
        "originBundleDigest",
        "repairCurrency",
        "findingDigest"
      ],
      "properties": {
        "findingId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[A-Za-z0-9._:-]+$"
        },
        "severity": {
          "enum": [
            "P0",
            "P1",
            "P2"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "evidence": {
          "type": "string",
          "minLength": 1,
          "maxLength": 768
        },
        "originTargetGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "originActionRef": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "adapterId",
            "actionId"
          ],
          "properties": {
            "adapterId": {
              "type": "string",
              "minLength": 1
            },
            "actionId": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "originResultDigest": {
          "$ref": "#/$defs/digest"
        },
        "originDeliveryManifest": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "artifactRef",
            "artifactRevision"
          ],
          "properties": {
            "artifactRef": {
              "type": "string",
              "minLength": 1
            },
            "artifactRevision": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "originDeliveryReviewBasisDigest": {
          "$ref": "#/$defs/digest"
        },
        "originBundleDigest": {
          "$ref": "#/$defs/digest"
        },
        "repairCurrency": {
          "$ref": "#/$defs/repair"
        },
        "findingDigest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "members"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "members": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/finding"
          }
        }
      }
    },
    "pageRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ordinal",
        "pageDigest",
        "memberCount",
        "firstFindingDigest",
        "lastFindingDigest"
      ],
      "properties": {
        "ordinal": {
          "type": "integer",
          "minimum": 0
        },
        "pageDigest": {
          "$ref": "#/$defs/digest"
        },
        "memberCount": {
          "type": "integer",
          "minimum": 1
        },
        "firstFindingDigest": {
          "$ref": "#/$defs/digest"
        },
        "lastFindingDigest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "findingCount",
        "pages"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "findingCount": {
          "type": "integer",
          "minimum": 0
        },
        "pages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pageRef"
          }
        }
      }
    }
  }
}
