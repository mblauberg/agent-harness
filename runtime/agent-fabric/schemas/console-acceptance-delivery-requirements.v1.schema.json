{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-fabric.local/schemas/console-acceptance-delivery-requirements.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "catalogueId",
    "phases",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "catalogueId": {
      "const": "console-acceptance-delivery-requirements-v1"
    },
    "phases": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preReviewRequirementIds", "postReviewAcceptanceRequirementIds"],
      "properties": {
        "preReviewRequirementIds": {
          "type": "array", "minItems": 44, "maxItems": 44, "uniqueItems": true,
          "items": {"type": "string", "pattern": "^CONSOLE-AC-[0-9]{3}$"}
        },
        "postReviewAcceptanceRequirementIds": {
          "type": "array", "minItems": 1, "maxItems": 1, "uniqueItems": true,
          "items": {"const": "CONSOLE-AC-033"}
        }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 45,
      "maxItems": 45,
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirementId",
        "sourceRole",
        "sourceRef",
        "evidenceSelectors"
      ],
      "properties": {
        "requirementId": {
          "type": "string",
          "pattern": "^CONSOLE-AC-[0-9]{3}$"
        },
        "sourceRole": {
          "const": "spec"
        },
        "sourceRef": {
          "const": "console-acceptance-v1.13"
        },
        "evidenceSelectors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "role",
              "registryKind",
              "selectorId",
              "cardinality",
              "requiredStatus"
            ],
            "properties": {
              "role": {
                "enum": [
                  "test",
                  "evaluation",
                  "load",
                  "migration",
                  "generated-contract",
                  "gate-decision",
                  "post-review-acceptance"
                ]
              },
              "registryKind": {
                "enum": [
                  "test-result.v1",
                  "evaluation-result.v1",
                  "load-result.v1",
                  "migration-result.v1",
                  "generated-contract.v1",
                  "human-gate-decision.v1",
                  "review-gate-decision.v1",
                  "post-review-acceptance-decision.v1"
                ]
              },
              "selectorId": {
                "type": "string",
                "pattern": "^(?:(?:runtime/agent-fabric|runtime/agent-fabric-console|runtime/agent-fabric-protocol)/(?:tests|schemas)/|skills/orchestrate/evals/|console-acceptance-)[A-Za-z0-9._/-]+$"
              },
              "cardinality": {
                "enum": [
                  "exactly-one",
                  "complete-nonempty-current-set"
                ]
              },
              "requiredStatus": {
                "enum": ["pass", "approved"]
              }
            },
            "oneOf": [
              { "properties": { "role": { "const": "test" }, "registryKind": { "const": "test-result.v1" }, "requiredStatus": { "const": "pass" } } },
              { "properties": { "role": { "const": "evaluation" }, "registryKind": { "const": "evaluation-result.v1" }, "requiredStatus": { "const": "pass" } } },
              { "properties": { "role": { "const": "load" }, "registryKind": { "const": "load-result.v1" }, "requiredStatus": { "const": "pass" } } },
              { "properties": { "role": { "const": "migration" }, "registryKind": { "const": "migration-result.v1" }, "requiredStatus": { "const": "pass" } } },
              { "properties": { "role": { "const": "generated-contract" }, "registryKind": { "const": "generated-contract.v1" }, "requiredStatus": { "const": "pass" } } },
              { "properties": { "role": { "const": "gate-decision" }, "registryKind": { "enum": ["human-gate-decision.v1", "review-gate-decision.v1"] }, "requiredStatus": { "const": "approved" } } },
              { "properties": { "role": { "const": "post-review-acceptance" }, "registryKind": { "const": "post-review-acceptance-decision.v1" }, "requiredStatus": { "const": "approved" } } }
            ]
          }
        }
      }
    }
  }
}
