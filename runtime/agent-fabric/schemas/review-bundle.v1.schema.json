{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-fabric.local/schemas/review-bundle.v1.schema.json",
  "oneOf": [
    {
      "$ref": "#/$defs/body"
    },
    {
      "$ref": "#/$defs/root"
    },
    {
      "$ref": "#/$defs/ref"
    }
  ],
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ordinal",
        "pageDigest",
        "byteLength"
      ],
      "properties": {
        "ordinal": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15
        },
        "pageDigest": {
          "$ref": "#/$defs/digest"
        },
        "byteLength": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65536
        }
      }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deliveryRunId",
        "reviewBasisRevision",
        "reviewBasisDigest",
        "deliveryManifestRef",
        "deliveryManifestObjectDigest",
        "deliveryRequirementMapObjectDigest"
      ],
      "properties": {
        "deliveryRunId": {
          "type": "string",
          "minLength": 1
        },
        "reviewBasisRevision": {
          "type": "integer",
          "minimum": 1
        },
        "reviewBasisDigest": {
          "$ref": "#/$defs/digest"
        },
        "deliveryManifestRef": {
          "type": "string",
          "minLength": 1
        },
        "deliveryManifestObjectDigest": {
          "$ref": "#/$defs/digest"
        },
        "deliveryRequirementMapObjectDigest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objectFormat",
        "baseObjectId",
        "headObjectId",
        "headTreeId",
        "indexTreeId",
        "worktreeState",
        "sourceStateDigest",
        "reviewDiffCodecDigest",
        "reviewDiffRulesDigest",
        "reviewDiffSetDigest"
      ],
      "properties": {
        "objectFormat": {
          "enum": [
            "sha1",
            "sha256"
          ]
        },
        "baseObjectId": {
          "type": "string"
        },
        "headObjectId": {
          "type": "string"
        },
        "headTreeId": {
          "type": "string"
        },
        "indexTreeId": {
          "type": "string"
        },
        "worktreeState": {
          "const": "clean"
        },
        "sourceStateDigest": {
          "$ref": "#/$defs/digest"
        },
        "reviewDiffCodecDigest": {
          "$ref": "#/$defs/digest"
        },
        "reviewDiffRulesDigest": {
          "$ref": "#/$defs/digest"
        },
        "reviewDiffSetDigest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "changedFile": {
      "type": "object", "additionalProperties": false,
      "required": ["ordinal","path","status","oldPath","beforeMode","afterMode","beforeObjectDigest","afterObjectDigest","diffObjectDigest"],
      "properties": {"ordinal":{"type":"integer","minimum":0},"path":{"type":"string","minLength":1},"status":{"enum":["added","modified","deleted","renamed","mode-changed"]},"oldPath":{"type":["string","null"]},"beforeMode":{"enum":["100644","100755","120000","160000",null]},"afterMode":{"enum":["100644","100755","120000","160000",null]},"beforeObjectDigest":{"oneOf":[{"$ref":"#/$defs/digest"},{"type":"null"}]},"afterObjectDigest":{"oneOf":[{"$ref":"#/$defs/digest"},{"type":"null"}]},"diffObjectDigest":{"$ref":"#/$defs/digest"}}
    },
    "evidence": {"type":"object","additionalProperties":false,"required":["ordinal","role","evidenceRef","evidenceRevision","registeredContentDigest","objectDigest"],"properties":{"ordinal":{"type":"integer","minimum":0},"role":{"enum":["delivery-manifest","delivery-requirement-map","accepted-scope","spec","adr","decision","test","evaluation","load","migration","generated-contract","coordination-gate-snapshot"]},"evidenceRef":{"type":"string","minLength":1},"evidenceRevision":{"type":"integer","minimum":1},"registeredContentDigest":{"$ref":"#/$defs/digest"},"objectDigest":{"$ref":"#/$defs/digest"}}},
    "findingPageRef": {"type":"object","additionalProperties":false,"required":["ordinal","pageDigest","memberCount","firstFindingDigest","lastFindingDigest"],"properties":{"ordinal":{"type":"integer","minimum":0},"pageDigest":{"$ref":"#/$defs/digest"},"memberCount":{"type":"integer","minimum":1},"firstFindingDigest":{"$ref":"#/$defs/digest"},"lastFindingDigest":{"$ref":"#/$defs/digest"}}},
    "objectRecord": {"type":"object","additionalProperties":false,"required":["ordinal","objectDigest","mediaType","byteLength","chunkDigests"],"properties":{"ordinal":{"type":"integer","minimum":0},"objectDigest":{"$ref":"#/$defs/digest"},"mediaType":{"enum":["application/octet-stream","application/vnd.agent-fabric.review-bundle-root.v1+json","application/vnd.agent-fabric.review-bundle-body.v1+json","application/vnd.agent-fabric.review-diff.v1+json","application/vnd.agent-fabric.review-finding-page.v1+json","application/vnd.agent-fabric.review-finding-set.v1+json"]},"byteLength":{"type":"integer","minimum":0,"maximum":16777216},"chunkDigests":{"type":"array","maxItems":256,"items":{"$ref":"#/$defs/digest"}}}},
    "body": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "bundleGeneration",
        "delivery",
        "repository",
        "changedFiles",
        "requiredEvidence",
        "carriedFindingSet",
        "objects",
        "bundleSearchIndexDigest",
        "riskReadMapDigest",
        "coverageDigest"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "bundleGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "delivery": {
          "$ref": "#/$defs/delivery"
        },
        "repository": {
          "$ref": "#/$defs/repository"
        },
        "changedFiles": {
          "type": "array",
          "maxItems": 4096,
          "items": {
            "$ref": "#/$defs/changedFile"
          }
        },
        "requiredEvidence": {
          "type": "array",
          "maxItems": 1024,
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "carriedFindingSet": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "findingSetDigest",
            "findingCount",
            "pages"
          ],
          "properties": {
            "findingSetDigest": {
              "$ref": "#/$defs/digest"
            },
            "findingCount": {
              "type": "integer",
              "minimum": 0
            },
            "pages": {
              "type": "array", "items": { "$ref": "#/$defs/findingPageRef" }
            }
          }
        },
        "objects": {
          "type": "array",
          "maxItems": 16384,
          "items": {
            "$ref": "#/$defs/objectRecord"
          }
        },
        "bundleSearchIndexDigest": {
          "$ref": "#/$defs/digest"
        },
        "riskReadMapDigest": {
          "$ref": "#/$defs/digest"
        },
        "coverageDigest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "root": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "bodyMediaType",
        "bodyByteLength",
        "manifestBodyDigest",
        "coverageDigest",
        "pages"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "bodyMediaType": {
          "const": "application/vnd.agent-fabric.review-bundle-body.v1+json"
        },
        "bodyByteLength": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576
        },
        "manifestBodyDigest": {
          "$ref": "#/$defs/digest"
        },
        "coverageDigest": {
          "$ref": "#/$defs/digest"
        },
        "pages": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "$ref": "#/$defs/page"
          }
        }
      }
    },
    "ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "bundleGeneration",
        "manifestBodyDigest",
        "manifestRootDigest",
        "coverageDigest",
        "bundleSearchIndexDigest",
        "riskReadMapDigest",
        "mandatoryReadSetDigest",
        "mandatoryReadCount",
        "mandatoryReadBytes"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "bundleGeneration": {
          "type": "integer",
          "minimum": 1
        },
        "manifestBodyDigest": {
          "$ref": "#/$defs/digest"
        },
        "manifestRootDigest": {
          "$ref": "#/$defs/digest"
        },
        "coverageDigest": {
          "$ref": "#/$defs/digest"
        },
        "bundleSearchIndexDigest": {
          "$ref": "#/$defs/digest"
        },
        "riskReadMapDigest": {
          "$ref": "#/$defs/digest"
        },
        "mandatoryReadSetDigest": {
          "$ref": "#/$defs/digest"
        },
        "mandatoryReadCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 80
        },
        "mandatoryReadBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6291456
        }
      }
    }
  }
}
