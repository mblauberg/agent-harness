{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://agent-fabric.local/schemas/review-profile.v1.schema.json",
  "type":"object","additionalProperties":false,
  "required":["schemaVersion","profileId","chairProfiles"],
  "properties":{
    "schemaVersion":{"const":1},"profileId":{"const":"spec05-four-slot-v1"},
    "chairProfiles":{"type":"array","minItems":2,"maxItems":2,"prefixItems":[{"$ref":"#/$defs/openaiProfile"},{"$ref":"#/$defs/anthropicProfile"}],"items":false}
  },
  "$defs":{
    "digest":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},
    "effort":{"oneOf":[
      {"type":"object","additionalProperties":false,"required":["kind","value"],"properties":{"kind":{"const":"applied"},"value":{"type":"string","minLength":1}}},
      {"type":"object","additionalProperties":false,"required":["kind"],"properties":{"kind":{"const":"inapplicable"}}}
    ]},
    "slot":{"type":"object","additionalProperties":false,"required":["slot","adapterClass","adapterId","providerFamily","model","requiredActualEndpointProvider","requestedEffort","resolvedEffort","sourceMode","providerTurnCeiling","internalStepCeiling","mandatoryReadOps","mandatoryReadBytes","explorationReadOps","explorationReadBytes","routeAliases","riskReadMapDigest"],"properties":{
      "slot":{"enum":["native","other-primary","cursor-grok","agy-gemini"]},"adapterClass":{"enum":["primary-native","equal-primary","cursor","agy"]},
      "adapterId":{"type":"string","minLength":1},"providerFamily":{"enum":["openai","anthropic","xai","google"]},"model":{"type":"string","minLength":1},"requiredActualEndpointProvider":{"type":"string","minLength":1},
      "requestedEffort":{"type":["string","null"],"minLength":1},"resolvedEffort":{"$ref":"#/$defs/effort"},"sourceMode":{"enum":["direct-portal","portal-helper"]},
      "providerTurnCeiling":{"type":"integer","minimum":1},"internalStepCeiling":{"type":"integer","minimum":0},"mandatoryReadOps":{"const":80},"mandatoryReadBytes":{"const":6291456},
      "explorationReadOps":{"enum":[32,48]},"explorationReadBytes":{"const":4194304},"routeAliases":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","minLength":1}},"riskReadMapDigest":{"const":"sha256:c8a4e424157f52c9e09165017ae717fa02798e4edab80e6388fa101816ef004d"}
    },"allOf":[
      {"oneOf":[
        {"type":"object","properties":{"requestedEffort":{"type":"string","minLength":1},"resolvedEffort":{"type":"object","required":["kind"],"properties":{"kind":{"const":"applied"}}}}},
        {"type":"object","properties":{"requestedEffort":{"type":"null"},"resolvedEffort":{"type":"object","required":["kind"],"properties":{"kind":{"const":"inapplicable"}}}}}
      ]},
      {"oneOf":[
        {"type":"object","properties":{"sourceMode":{"const":"direct-portal"},"providerTurnCeiling":{"const":128},"internalStepCeiling":{"const":0},"explorationReadOps":{"const":32}}},
        {"type":"object","properties":{"sourceMode":{"const":"portal-helper"},"providerTurnCeiling":{"const":1},"internalStepCeiling":{"const":128},"explorationReadOps":{"const":48}}}
      ]}
    ]},
    "slots":{"type":"array","minItems":4,"maxItems":4,"prefixItems":[
      {"allOf":[{"$ref":"#/$defs/slot"},{"type":"object","properties":{"slot":{"const":"native"},"adapterClass":{"const":"primary-native"}}}]},
      {"allOf":[{"$ref":"#/$defs/slot"},{"type":"object","properties":{"slot":{"const":"other-primary"},"adapterClass":{"const":"equal-primary"}}}]},
      {"allOf":[{"$ref":"#/$defs/slot"},{"type":"object","properties":{"slot":{"const":"cursor-grok"},"adapterClass":{"const":"cursor"},"providerFamily":{"const":"xai"}}}]},
      {"allOf":[{"$ref":"#/$defs/slot"},{"type":"object","properties":{"slot":{"const":"agy-gemini"},"adapterClass":{"const":"agy"},"providerFamily":{"const":"google"}}}]}
    ],"items":false},
    "openaiProfile":{"type":"object","additionalProperties":false,"required":["targetChairFamily","slots"],"properties":{"targetChairFamily":{"const":"openai"},"slots":{"$ref":"#/$defs/slots"}}},
    "anthropicProfile":{"type":"object","additionalProperties":false,"required":["targetChairFamily","slots"],"properties":{"targetChairFamily":{"const":"anthropic"},"slots":{"$ref":"#/$defs/slots"}}}
  }
}
