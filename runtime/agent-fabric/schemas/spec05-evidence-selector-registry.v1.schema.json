{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-fabric.local/schemas/spec05-evidence-selector-registry.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "registryId", "sources", "selectors"],
  "properties": {
    "schemaVersion": {"const": 1},
    "registryId": {"const": "spec05-evidence-selector-registry-v1"},
    "sources": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"type":"object","additionalProperties":false,"required":["sourceRef","sourceRole","artifactRef","version"],
        "properties":{"sourceRef":{"type":"string","minLength":1},"sourceRole":{"enum":["spec","adr","decision"]},
          "artifactRef":{"type":"string","minLength":1},"version":{"type":"string","minLength":1}}}
    },
    "selectors": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["selectorId", "requirementId", "proofDomain", "owner", "state", "artifactRef"],
        "properties": {
          "selectorId": {"type": "string", "minLength": 1},
          "requirementId": {"type": "string", "pattern": "^SPEC05-AC-[0-9]{3}$"},
          "proofDomain": {"type": "string", "pattern": "^[a-z0-9-]+$"},
          "owner": {"type": "string", "pattern": "^[a-z0-9-]+$"},
          "state": {"enum": ["implemented", "planned-test", "gate-pending", "human-gate", "post-review-gate"]},
          "artifactRef": {"type": ["string", "null"], "minLength": 1}
        }
      }
    }
  }
}
