{
  "name": "@local/agent-fabric",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "bin": {
    "agent-fabric": "dist/cli/main.js",
    "agent-fabric-mcp": "dist/mcp/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:acceptance": "vitest run tests/acceptance",
    "test:load": "vitest run tests/performance",
    "test:evaluation": "vitest run tests/evaluation",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.206",
    "@modelcontextprotocol/sdk": "1.29.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "better-sqlite3": "12.11.1",
    "uuid": "14.0.1",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "26.1.1",
    "tsx": "4.23.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
